# Application
NODE_ENV=development
PORT=3000

# Database - SQLite (Current)
DATABASE_URL="file:./dev.db"

# Database - PostgreSQL (For Production)
# Uncomment these when ready to switch to PostgreSQL
# POSTGRES_USER=stratix
# POSTGRES_PASSWORD=stratix123
# POSTGRES_DB=stratix_db
# POSTGRES_PORT=5432
# DATABASE_URL="postgresql://stratix:stratix123@localhost:5432/stratix_db?schema=public"

# PgAdmin (Optional)
# PGADMIN_EMAIL=admin@stratix.com
# PGADMIN_PASSWORD=admin123
# PGADMIN_PORT=5050

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production-use-random-string

# CORS (Production)
# ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
