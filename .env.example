# =========================================
# STRATIX — Environment Variables
# =========================================

# ----- Application -----
NODE_ENV=development
PORT=3000

# ----- Database -----
# 🖥️ LOCAL (SQLite — Default)
DATABASE_URL="file:./dev.db"

# 🚂 RAILWAY / PRODUCTION (PostgreSQL)
# Railway provides this automatically when you add a PostgreSQL plugin.
# Just add a PostgreSQL service in Railway and it will set DATABASE_URL for you.
# Example format:
# DATABASE_URL="postgresql://user:password@host:5432/database?schema=public"

# ----- JWT -----
# ⚠️ IMPORTANT: Change this in production! Use a random 64+ character string.
JWT_SECRET=your-super-secret-jwt-key-change-in-production-use-random-string

# ----- CORS (Production) -----
# Set your domain(s) here for production. Comma-separated.
# ALLOWED_ORIGINS=https://your-app.railway.app,https://yourdomain.com

# ----- Optional: Docker PostgreSQL (Local) -----
# Uncomment these if using docker-compose for local PostgreSQL
# POSTGRES_USER=stratix
# POSTGRES_PASSWORD=stratix123
# POSTGRES_DB=stratix_db
# POSTGRES_PORT=5432
# DATABASE_URL="postgresql://stratix:stratix123@localhost:5432/stratix_db?schema=public"

# ----- Optional: PgAdmin -----
# PGADMIN_EMAIL=admin@stratix.com
# PGADMIN_PASSWORD=admin123
# PGADMIN_PORT=5050
