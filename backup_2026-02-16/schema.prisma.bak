// =========================================
// STRATIX - Updated Schema with Hybrid Model
// Date: February 16, 2026
// Combining: Reference Tables + Member Model + Audit Log + Strategic Features
// =========================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite" // Change to "postgresql" when ready
  url      = env("DATABASE_URL")
}

// =========================================
// 1. ENUMS
// =========================================

// Enums removed for SQLite compatibility; using string fields with defaults instead

// =========================================
// 2. REFERENCE TABLES (Classification System)
// =========================================

/// القطاع (حكومي، خاص، غير ربحي)
model Sector {
  id        String     @id @default(cuid())
  nameAr    String     @unique
  nameEn    String     @unique
  code      String?    @unique
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  
  entities  Entity[]

  @@map("ref_sectors")
}

/// النشاط الاقتصادي (صحي، تعليمي، صناعي...)
model Industry {
  id        String     @id @default(cuid())
  nameAr    String     @unique
  nameEn    String     @unique
  code      String?    @unique
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  entities  Entity[]

  @@map("ref_industries")
}

/// نوع الكيان (مستشفى، وزارة، جمعية...)
model EntityType {
  id        String     @id @default(cuid())
  nameAr    String     @unique
  nameEn    String     @unique
  code      String?    @unique
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  entities  Entity[]

  @@map("ref_entity_types")
}

// =========================================
// 3. IDENTITY CORE (Users & Entities)
// =========================================

/// User model - بسيط (بدون entity مباشر)
model User {
  id        String    @id @default(cuid())
  email     String    @unique
  password  String
  name      String
  avatarUrl String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  // علاقات
  memberships Member[]
  auditLogs   AuditLog[]

  @@map("users")
}

/// Entity model - الكيان (المستشفى، الوزارة، الشركة...)
model Entity {
  id          String   @id @default(cuid())
  legalName   String   // الاسم الرسمي (إلزامي)
  displayName String?  // الاسم المختصر
  
  // 🔗 الربط بشجرة التصنيف (اختياري)
  sectorId    String?
  industryId  String?
  typeId      String?
  
  logoUrl     String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // العلاقات مع التصنيفات
  sector      Sector?     @relation(fields: [sectorId], references: [id], onDelete: SetNull)
  industry    Industry?   @relation(fields: [industryId], references: [id], onDelete: SetNull)
  entityType  EntityType? @relation(fields: [typeId], references: [id], onDelete: SetNull)

  // العلاقات مع النظام
  members             Member[]
  strategyVersions    StrategyVersion[]
  assessments         Assessment[]
  auditLogs           AuditLog[]
  financialDecisions  FinancialDecision[]
  integrations        Integration[]

  @@index([sectorId])
  @@index([industryId])
  @@index([typeId])
  @@map("entities")
}

/// Member model - ربط User و Entity مع الأدوار
model Member {
  id        String   @id @default(cuid())
  userId    String
  entityId  String
  role      String   @default("VIEWER")
  joinedAt  DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  entity    Entity   @relation(fields: [entityId], references: [id], onDelete: Cascade)

  @@unique([userId, entityId]) // المستخدم لا يتكرر في نفس الكيان
  @@index([userId])
  @@index([entityId])
  @@map("members")
}

// =========================================
// 4. STRATEGY FOUNDATION
// =========================================

/// نسخة الاستراتيجية مع تتبع التطور التاريخي
model StrategyVersion {
  id              String    @id @default(cuid())
  entityId        String
  versionNumber   Int
  status          String    @default("DRAFT")
  
  // 🔗 Linked List - تتبع عمليات Pivot
  pivotedFromId   String?
  createdAt       DateTime  @default(now())
  activatedAt     DateTime?
  updatedAt       DateTime  @updatedAt

  entity          Entity    @relation(fields: [entityId], references: [id], onDelete: Cascade)
  prevVersion     StrategyVersion? @relation("VersionLineage", fields: [pivotedFromId], references: [id])
  nextVersions    StrategyVersion[] @relation("VersionLineage")
  
  // علاقات مع الأهداف والمؤشرات
  objectives      StrategicObjective[]
  kpis            KPI[]
  initiatives     StrategicInitiative[]
  reviews         StrategicReview[]
  choices         StrategicChoice[]
  risks           StrategicRisk[]

  @@unique([entityId, versionNumber])
  @@index([entityId])
  @@index([pivotedFromId])
  @@map("strategy_versions")
}

/// الأهداف الاستراتيجية
model StrategicObjective {
  id          String    @id @default(cuid())
  versionId   String
  title       String
  description String?
  status      String    @default("DRAFT")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  version     StrategyVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)
  kpis        KPI[]

  @@index([versionId])
  @@map("strategic_objectives")
}

/// مؤشرات الأداء (KPI)
model KPI {
  id          String    @id @default(cuid())
  versionId   String
  objectiveId String?
  name        String
  nameAr      String?
  description String?
  target      Float
  actual      Float?
  unit        String    @default("%")
  status      String    @default("ON_TRACK")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  version     StrategyVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)
  objective   StrategicObjective? @relation(fields: [objectiveId], references: [id], onDelete: SetNull)
  diagnoses   KpiDiagnosis[]

  @@index([versionId])
  @@index([objectiveId])
  @@map("kpis")
}

/// المبادرات الاستراتيجية
model StrategicInitiative {
  id          String    @id @default(cuid())
  versionId   String
  title       String
  description String?
  owner       String?
  status      String    @default("PLANNED")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  version     StrategyVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)

  @@index([versionId])
  @@map("strategic_initiatives")
}

/// المراجعات الاستراتيجية
model StrategicReview {
  id          String    @id @default(cuid())
  versionId   String
  title       String
  reviewDate  DateTime
  status      String    @default("PENDING")
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  version     StrategyVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)

  @@index([versionId])
  @@map("strategic_reviews")
}

// =========================================
// 5. ASSESSMENTS
// =========================================

/// التقييمات الاستراتيجية
model Assessment {
  id          String    @id @default(cuid())
  entityId    String
  title       String
  description String?
  status      String    @default("DRAFT")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  entity          Entity    @relation(fields: [entityId], references: [id], onDelete: Cascade)
  dimensions      Dimension[]
  analysisPoints  AnalysisPoint[]

  @@index([entityId])
  @@map("assessments")
}

/// أبعاد التقييم
model Dimension {
  id            String    @id @default(cuid())
  assessmentId  String
  name          String
  description   String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  assessment    Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  criteria      Criterion[]

  @@index([assessmentId])
  @@map("dimensions")
}

/// معايير التقييم
model Criterion {
  id          String    @id @default(cuid())
  dimensionId String
  name        String
  description String?
  score       Float?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  dimension   Dimension @relation(fields: [dimensionId], references: [id], onDelete: Cascade)

  @@index([dimensionId])
  @@map("criteria")
}

// =========================================
// 6. STRATEGIC CHOICES & RISKS
// =========================================

/// الخيارات الاستراتيجية
model StrategicChoice {
  id          String    @id @default(cuid())
  versionId   String
  title       String
  description String?
  status      String    @default("ACTIVE")   // ACTIVE, COMPLETED, DROPPED
  priority    String    @default("MEDIUM")   // HIGH, MEDIUM, LOW
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  version     StrategyVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)
  risks       StrategicRisk[]

  @@index([versionId])
  @@map("strategic_choices")
}

/// المخاطر الاستراتيجية
model StrategicRisk {
  id              String    @id @default(cuid())
  choiceId        String?
  versionId       String
  title           String
  description     String?
  probability     String    @default("MEDIUM")  // HIGH, MEDIUM, LOW
  impact          String    @default("MEDIUM")   // HIGH, MEDIUM, LOW
  mitigation      String?
  owner           String?
  status          String    @default("OPEN")     // OPEN, MITIGATED, CLOSED
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  choice          StrategicChoice? @relation(fields: [choiceId], references: [id], onDelete: SetNull)
  version         StrategyVersion  @relation(fields: [versionId], references: [id], onDelete: Cascade)

  @@index([choiceId])
  @@index([versionId])
  @@map("strategic_risks")
}

// =========================================
// 7. CORRECTIONS & DIAGNOSES
// =========================================

/// تشخيص مؤشرات الأداء
model KpiDiagnosis {
  id          String    @id @default(cuid())
  kpiId       String
  diagnosis   String
  severity    String    @default("MEDIUM")  // HIGH, MEDIUM, LOW
  rootCause   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  kpi         KPI       @relation(fields: [kpiId], references: [id], onDelete: Cascade)
  corrections CorrectionAction[]

  @@index([kpiId])
  @@map("kpi_diagnoses")
}

/// الإجراءات التصحيحية
model CorrectionAction {
  id            String    @id @default(cuid())
  diagnosisId   String
  title         String
  description   String?
  assignee      String?
  status        String    @default("PENDING")  // PENDING, IN_PROGRESS, COMPLETED
  dueDate       DateTime?
  completedAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  diagnosis     KpiDiagnosis @relation(fields: [diagnosisId], references: [id], onDelete: Cascade)

  @@index([diagnosisId])
  @@map("correction_actions")
}

// =========================================
// 8. STRATEGY ANALYSIS
// =========================================

/// نقاط التحليل الاستراتيجي (SWOT)
model AnalysisPoint {
  id            String    @id @default(cuid())
  assessmentId  String
  type          String    // STRENGTH, WEAKNESS, OPPORTUNITY, THREAT
  title         String
  description   String?
  impact        String    @default("MEDIUM")  // HIGH, MEDIUM, LOW
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  assessment    Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)

  @@index([assessmentId])
  @@index([type])
  @@map("analysis_points")
}

// =========================================
// 9. FINANCIAL DECISIONS
// =========================================

/// القرارات المالية
model FinancialDecision {
  id            String    @id @default(cuid())
  entityId      String
  title         String
  description   String?
  amount        Float?
  currency      String    @default("SAR")
  type          String    @default("INVESTMENT")  // INVESTMENT, COST_REDUCTION, REALLOCATION, OTHER
  status        String    @default("PROPOSED")    // PROPOSED, APPROVED, REJECTED, IMPLEMENTED
  impact        String?   // وصف الأثر
  decisionDate  DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  entity        Entity    @relation(fields: [entityId], references: [id], onDelete: Cascade)

  @@index([entityId])
  @@map("financial_decisions")
}

// =========================================
// 10. INTEGRATIONS
// =========================================

/// إعدادات التكامل الخارجي
model Integration {
  id            String    @id @default(cuid())
  entityId      String
  provider      String    // BITRIX24, ZAPIER, CUSTOM
  name          String
  webhookUrl    String?
  apiKey        String?
  isActive      Boolean   @default(false)
  config        String?   // JSON as string
  lastSyncAt    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  entity        Entity    @relation(fields: [entityId], references: [id], onDelete: Cascade)

  @@index([entityId])
  @@map("integrations")
}

// =========================================
// 11. AUDIT & GOVERNANCE
// =========================================

/// سجل الرقابة والحوكمة
model AuditLog {
  id        String   @id @default(cuid())
  entityId  String
  userId    String
  action    String   // 'STRATEGY_PIVOT', 'ENTITY_UPDATE', 'MEMBER_ADDED'
  details   String?
  oldData   String?  // JSON as string
  newData   String?  // JSON as string
  createdAt DateTime @default(now())

  entity    Entity   @relation(fields: [entityId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([entityId])
  @@index([userId])
  @@index([createdAt])
  @@map("audit_logs")
}
