// =========================================
// STRATIX - Strategic Operating System
// Schema v2.0 — Phase 1 Upgrade
// Date: February 16, 2026
// Strategy: Additive changes only (no breaking changes)
// =========================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// =========================================
// 1. REFERENCE TABLES (Classification System)
// =========================================

/// القطاع (حكومي، خاص، غير ربحي)
model Sector {
  id        String     @id @default(cuid())
  nameAr    String     @unique
  nameEn    String     @unique
  code      String?    @unique
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  
  entities  Entity[]

  @@map("ref_sectors")
}

/// النشاط الاقتصادي (صحي، تعليمي، صناعي...)
model Industry {
  id        String     @id @default(cuid())
  nameAr    String     @unique
  nameEn    String     @unique
  code      String?    @unique
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  entities  Entity[]

  @@map("ref_industries")
}

/// نوع الكيان (مستشفى، وزارة، جمعية...)
model EntityType {
  id        String     @id @default(cuid())
  nameAr    String     @unique
  nameEn    String     @unique
  code      String?    @unique
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  entities  Entity[]

  @@map("ref_entity_types")
}

// =========================================
// 2. IDENTITY CORE (Users & Entities)
// =========================================

/// User model
model User {
  id        String    @id @default(cuid())
  email     String    @unique
  password  String
  name      String
  avatarUrl String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  memberships Member[]
  auditLogs   AuditLog[]

  @@map("users")
}

/// Entity model - الكيان (المستشفى، الوزارة، الشركة...)
model Entity {
  id          String   @id @default(cuid())
  legalName   String
  displayName String?
  
  // 🔗 الربط بشجرة التصنيف (اختياري)
  sectorId    String?
  industryId  String?
  typeId      String?
  
  // ✨ حقول جديدة — Phase 1
  size        String?    // MICRO, SMALL, MEDIUM, LARGE, ENTERPRISE
  school      String?    // المدرسة الإدارية (BALANCED_SCORECARD, OKR, HOSHIN_KANRI, etc.)
  
  logoUrl     String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // العلاقات مع التصنيفات
  sector      Sector?     @relation(fields: [sectorId], references: [id], onDelete: SetNull)
  industry    Industry?   @relation(fields: [industryId], references: [id], onDelete: SetNull)
  entityType  EntityType? @relation(fields: [typeId], references: [id], onDelete: SetNull)

  // العلاقات مع النظام
  members             Member[]
  strategyVersions    StrategyVersion[]
  assessments         Assessment[]
  auditLogs           AuditLog[]
  financialDecisions  FinancialDecision[]
  integrations        Integration[]

  @@index([sectorId])
  @@index([industryId])
  @@index([typeId])
  @@map("entities")
}

/// Member model - ربط User و Entity مع الأدوار
model Member {
  id        String   @id @default(cuid())
  userId    String
  entityId  String
  role      String   @default("VIEWER")  // OWNER, ADMIN, EDITOR, VIEWER
  joinedAt  DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  entity    Entity   @relation(fields: [entityId], references: [id], onDelete: Cascade)

  @@unique([userId, entityId])
  @@index([userId])
  @@index([entityId])
  @@map("members")
}

// =========================================
// 3. STRATEGY FOUNDATION
// =========================================

/// نسخة الاستراتيجية — القلب الرئيسي للنظام
model StrategyVersion {
  id              String    @id @default(cuid())
  entityId        String
  versionNumber   Int
  status          String    @default("DRAFT")   // DRAFT, ACTIVE, ARCHIVED, PENDING
  
  // ✨ حقول جديدة — Phase 1
  name            String?     // اسم وصفي: "خطة 2024"، "سيناريو التحول الرقمي"
  description     String?     // وصف مختصر للنسخة
  isActive        Boolean  @default(false)  // نسخة واحدة فقط نشطة لكل كيان
  createdBy       String?     // ID المستخدم الذي أنشأها
  approvedBy      String?     // ID المستخدم الذي اعتمدها
  approvedAt      DateTime?   // تاريخ الاعتماد
  
  // 🔗 Linked List - تتبع عمليات Pivot
  pivotedFromId   String?
  createdAt       DateTime  @default(now())
  activatedAt     DateTime?
  updatedAt       DateTime  @updatedAt

  entity          Entity    @relation(fields: [entityId], references: [id], onDelete: Cascade)
  prevVersion     StrategyVersion? @relation("VersionLineage", fields: [pivotedFromId], references: [id])
  nextVersions    StrategyVersion[] @relation("VersionLineage")
  
  // العلاقات الاستراتيجية
  directions      StrategicDirection[]   // ✨ جديد — الهرم الاستراتيجي
  externalAnalyses ExternalAnalysis[]    // ✨ جديد — PESTEL + Porter
  objectives      StrategicObjective[]
  kpis            KPI[]
  initiatives     StrategicInitiative[]
  reviews         StrategicReview[]
  choices         StrategicChoice[]
  risks           StrategicRisk[]

  @@unique([entityId, versionNumber])
  @@index([entityId])
  @@index([pivotedFromId])
  @@map("strategy_versions")
}

// =========================================
// 4. STRATEGIC DIRECTION (NEW ✨)
// رؤية، رسالة، قيم، قضايا كبرى
// =========================================

/// الاتجاه الاستراتيجي (الهرم الاستراتيجي)
model StrategicDirection {
  id          String   @id @default(cuid())
  versionId   String
  type        String   // VISION, MISSION, VALUES, ISSUES, LONG_TERM_GOALS
  content     String   // النص الكامل
  order       Int      @default(0)  // الترتيب (مهم للقيم المتعددة)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  version     StrategyVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)

  @@index([versionId])
  @@index([type])
  @@map("strategic_directions")
}

// =========================================
// 5. EXTERNAL ANALYSIS (NEW ✨)
// PESTEL + Porter's Five Forces
// =========================================

/// التحليل الخارجي
model ExternalAnalysis {
  id          String   @id @default(cuid())
  versionId   String
  type        String   // POLITICAL, ECONOMIC, SOCIAL, TECHNOLOGICAL, ENVIRONMENTAL, LEGAL,
                       // PORTER_RIVALRY, PORTER_NEW_ENTRANTS, PORTER_SUBSTITUTES, PORTER_SUPPLIERS, PORTER_BUYERS
  factor      String   // العامل (مثال: "تغيير سياسة الضرائب")
  impact      String   @default("MEDIUM")  // HIGH, MEDIUM, LOW
  probability Float?   // 0-1 احتمالية التأثير
  trend       String?  // INCREASING, STABLE, DECREASING — اتجاه العامل
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  version     StrategyVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)

  @@index([versionId])
  @@index([type])
  @@map("external_analyses")
}

// =========================================
// 6. STRATEGIC OBJECTIVES & KPIs (ENHANCED ✨)
// BSC + OKR Support
// =========================================

/// الأهداف الاستراتيجية — محسّنة مع BSC + OKR
model StrategicObjective {
  id          String    @id @default(cuid())
  versionId   String
  title       String
  description String?
  status      String    @default("DRAFT")
  
  // ✨ حقول جديدة — Phase 1
  parentId    String?     // 🔗 OKR Hierarchy — الهدف الأب
  perspective String?     // BSC: FINANCIAL, CUSTOMER, INTERNAL_PROCESS, LEARNING_GROWTH
  weight      Float?      @default(1.0)  // أهمية نسبية
  baselineValue Float?    // القيمة الأساسية (خط الأساس)
  targetValue Float?      // القيمة المستهدفة
  deadline    DateTime?   // الموعد النهائي
  ownerId     String?     // مسؤول الهدف (Member ID)
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  version     StrategyVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)
  parent      StrategicObjective? @relation("ObjectiveHierarchy", fields: [parentId], references: [id])
  children    StrategicObjective[] @relation("ObjectiveHierarchy")
  kpis        KPI[]

  @@index([versionId])
  @@index([parentId])
  @@map("strategic_objectives")
}

/// مؤشرات الأداء (KPI) — محسّنة
model KPI {
  id          String    @id @default(cuid())
  versionId   String
  objectiveId String?
  name        String
  nameAr      String?
  description String?
  target      Float
  actual      Float?
  unit        String    @default("%")
  status      String    @default("ON_TRACK")  // ON_TRACK, AT_RISK, OFF_TRACK, ACHIEVED
  
  // ✨ حقول جديدة — Phase 1
  formula         String?   // صيغة الحساب (مثال: "Revenue / Employees")
  dataSource      String?   // مصدر البيانات (مثال: "ERP System", "Manual Entry")
  frequency       String?   @default("MONTHLY")  // DAILY, WEEKLY, MONTHLY, QUARTERLY, YEARLY
  warningThreshold Float?   // نسبة مئوية: تنبيه عند < هذه القيمة (مثال: 0.8 = 80%)
  criticalThreshold Float?  // نسبة مئوية: خطر عند < هذه القيمة (مثال: 0.5 = 50%)
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  version     StrategyVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)
  objective   StrategicObjective? @relation(fields: [objectiveId], references: [id], onDelete: SetNull)
  diagnoses   KpiDiagnosis[]
  entries     KPIEntry[]    // ✨ جديد — إدخال البيانات الدوري

  @@index([versionId])
  @@index([objectiveId])
  @@map("kpis")
}

// =========================================
// 7. KPI DATA ENTRY (NEW ✨)
// إدخال القيم الفعلية دورياً
// =========================================

/// إدخالات الأداء — سجل تاريخي لقيم KPI
model KPIEntry {
  id          String   @id @default(cuid())
  kpiId       String
  value       Float      // القيمة الفعلية
  periodStart DateTime   // بداية الفترة
  periodEnd   DateTime   // نهاية الفترة
  enteredBy   String?    // ID المستخدم الذي أدخل البيانات
  status      String    @default("CONFIRMED")  // DRAFT, CONFIRMED
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  kpi         KPI @relation(fields: [kpiId], references: [id], onDelete: Cascade)

  @@index([kpiId])
  @@index([periodStart])
  @@map("kpi_entries")
}

// =========================================
// 8. STRATEGIC INITIATIVES (ENHANCED ✨)
// =========================================

/// المبادرات الاستراتيجية — محسّنة
model StrategicInitiative {
  id          String    @id @default(cuid())
  versionId   String
  title       String
  description String?
  owner       String?
  status      String    @default("PLANNED")  // PLANNED, IN_PROGRESS, COMPLETED, CANCELLED, ON_HOLD
  
  // ✨ حقول جديدة — Phase 1
  startDate   DateTime?   // تاريخ البداية
  endDate     DateTime?   // تاريخ النهاية
  progress    Float?      @default(0)  // 0-100 نسبة الإنجاز
  budget      Float?      // الميزانية المخصصة
  kpiId       String?     // ربط بمؤشر الأداء المستهدف
  priority    String?     @default("MEDIUM")  // HIGH, MEDIUM, LOW
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  version     StrategyVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)

  @@index([versionId])
  @@map("strategic_initiatives")
}

// =========================================
// 9. STRATEGIC REVIEWS (ENHANCED ✨)
// =========================================

/// المراجعات الاستراتيجية — محسّنة مع محرك القرارات
model StrategicReview {
  id          String    @id @default(cuid())
  versionId   String
  title       String
  reviewDate  DateTime
  status      String    @default("PENDING")  // PENDING, IN_PROGRESS, COMPLETED
  notes       String?
  
  // ✨ حقول جديدة — Phase 1
  type            String?   @default("QUARTERLY_REVIEW")  // QUARTERLY_REVIEW, ANNUAL_REVIEW, AD_HOC, AUDIT
  decision        String?   // CONTINUE, ADJUST, PIVOT — محرك القرارات
  summary         String?   // ملخص تنفيذي
  findings        String?   // النتائج والملاحظات
  recommendations String?   // التوصيات
  overallScore    Float?    // متوسط أداء النسخة (0-100)
  conductedBy     String?   // المراجع
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  version     StrategyVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)

  @@index([versionId])
  @@map("strategic_reviews")
}

// =========================================
// 10. ASSESSMENTS (Unchanged)
// =========================================

/// التقييمات الاستراتيجية
model Assessment {
  id          String    @id @default(cuid())
  entityId    String
  title       String
  description String?
  status      String    @default("DRAFT")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  entity          Entity    @relation(fields: [entityId], references: [id], onDelete: Cascade)
  dimensions      Dimension[]
  analysisPoints  AnalysisPoint[]

  @@index([entityId])
  @@map("assessments")
}

/// أبعاد التقييم
model Dimension {
  id            String    @id @default(cuid())
  assessmentId  String
  name          String
  description   String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  assessment    Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  criteria      Criterion[]

  @@index([assessmentId])
  @@map("dimensions")
}

/// معايير التقييم
model Criterion {
  id          String    @id @default(cuid())
  dimensionId String
  name        String
  description String?
  score       Float?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  dimension   Dimension @relation(fields: [dimensionId], references: [id], onDelete: Cascade)

  @@index([dimensionId])
  @@map("criteria")
}

// =========================================
// 11. STRATEGIC CHOICES & RISKS (ENHANCED ✨)
// =========================================

/// الخيارات الاستراتيجية — محسّنة مع Ansoff + Porter
model StrategicChoice {
  id              String    @id @default(cuid())
  versionId       String
  title           String
  description     String?
  status          String    @default("ACTIVE")   // ACTIVE, COMPLETED, DROPPED
  priority        String    @default("MEDIUM")   // HIGH, MEDIUM, LOW
  
  // ✨ حقول جديدة — Phase 1
  choiceType          String?   // MARKET_PENETRATION, MARKET_DEVELOPMENT, PRODUCT_DEVELOPMENT,
                                // DIVERSIFICATION, COST_LEADERSHIP, DIFFERENTIATION, FOCUS, BEST_COST
  marketAttractiveness Int?     // 1-5 جاذبية السوق
  competitiveAdvantage Int?     // 1-5 الميزة التنافسية
  feasibility         Int?      // 1-5 قابلية التنفيذ
  riskLevel           String?   @default("MEDIUM")  // HIGH, MEDIUM, LOW
  isSelected          Boolean  @default(false)  // هل تم اختياره كخيار معتمد؟
  requiredCapabilities String?  // القدرات المطلوبة

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  version     StrategyVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)
  risks       StrategicRisk[]

  @@index([versionId])
  @@map("strategic_choices")
}

/// المخاطر الاستراتيجية — محسّنة مع تقييم كمّي
model StrategicRisk {
  id              String    @id @default(cuid())
  choiceId        String?
  versionId       String
  title           String
  description     String?
  probability     String    @default("MEDIUM")  // الاحتمالية النوعية (للتوافق مع البيانات القديمة)
  impact          String    @default("MEDIUM")  // الأثر النوعي
  mitigation      String?
  owner           String?
  status          String    @default("OPEN")    // OPEN, MITIGATED, CLOSED, IDENTIFIED, ASSESSING, MONITORING

  // ✨ حقول جديدة — Phase 1
  category        String?   // STRATEGIC, OPERATIONAL, FINANCIAL, COMPLIANCE, REPUTATIONAL
  probabilityScore Int?     // 1-5 الاحتمالية الكمّية
  impactScore     Int?      // 1-5 الأثر الكمّي
  riskScore       Int?      // probability * impact (محسوب تلقائياً)
  contingency     String?   // خطة الطوارئ

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  choice          StrategicChoice? @relation(fields: [choiceId], references: [id], onDelete: SetNull)
  version         StrategyVersion  @relation(fields: [versionId], references: [id], onDelete: Cascade)

  @@index([choiceId])
  @@index([versionId])
  @@map("strategic_risks")
}

// =========================================
// 12. CORRECTIONS & DIAGNOSES (Unchanged)
// =========================================

/// تشخيص مؤشرات الأداء
model KpiDiagnosis {
  id          String    @id @default(cuid())
  kpiId       String
  diagnosis   String
  severity    String    @default("MEDIUM")
  rootCause   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  kpi         KPI       @relation(fields: [kpiId], references: [id], onDelete: Cascade)
  corrections CorrectionAction[]

  @@index([kpiId])
  @@map("kpi_diagnoses")
}

/// الإجراءات التصحيحية
model CorrectionAction {
  id            String    @id @default(cuid())
  diagnosisId   String
  title         String
  description   String?
  assignee      String?
  status        String    @default("PENDING")
  dueDate       DateTime?
  completedAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  diagnosis     KpiDiagnosis @relation(fields: [diagnosisId], references: [id], onDelete: Cascade)

  @@index([diagnosisId])
  @@map("correction_actions")
}

// =========================================
// 13. STRATEGY ANALYSIS (SWOT) (Unchanged)
// =========================================

/// نقاط التحليل الاستراتيجي (SWOT)
model AnalysisPoint {
  id            String    @id @default(cuid())
  assessmentId  String
  type          String    // STRENGTH, WEAKNESS, OPPORTUNITY, THREAT
  title         String
  description   String?
  impact        String    @default("MEDIUM")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  assessment    Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)

  @@index([assessmentId])
  @@index([type])
  @@map("analysis_points")
}

// =========================================
// 14. FINANCIAL DECISIONS (Unchanged)
// =========================================

/// القرارات المالية
model FinancialDecision {
  id            String    @id @default(cuid())
  entityId      String
  title         String
  description   String?
  amount        Float?
  currency      String    @default("SAR")
  type          String    @default("INVESTMENT")
  status        String    @default("PROPOSED")
  impact        String?
  decisionDate  DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  entity        Entity    @relation(fields: [entityId], references: [id], onDelete: Cascade)

  @@index([entityId])
  @@map("financial_decisions")
}

// =========================================
// 15. INTEGRATIONS (Unchanged)
// =========================================

/// إعدادات التكامل الخارجي
model Integration {
  id            String    @id @default(cuid())
  entityId      String
  provider      String
  name          String
  webhookUrl    String?
  apiKey        String?
  isActive      Boolean   @default(false)
  config        String?
  lastSyncAt    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  entity        Entity    @relation(fields: [entityId], references: [id], onDelete: Cascade)

  @@index([entityId])
  @@map("integrations")
}

// =========================================
// 16. STRATEGIC ALERTS (NEW ✨)
// نظام التنبيهات الآلية
// =========================================

/// التنبيهات الاستراتيجية
model StrategicAlert {
  id          String   @id @default(cuid())
  entityId    String
  type        String   // KPI_WARNING, KPI_CRITICAL, REVIEW_OVERDUE, INITIATIVE_DELAYED,
                       // VERSION_PENDING, RISK_HIGH, HEALTH_LOW
  severity    String   @default("WARNING")  // INFO, WARNING, CRITICAL
  title       String
  message     String?
  referenceId String?  // ID العنصر المرتبط (KPI ID, Review ID, etc.)
  referenceType String? // KPI, REVIEW, INITIATIVE, RISK, VERSION
  isRead      Boolean  @default(false)
  isDismissed Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([entityId])
  @@index([type])
  @@index([isRead])
  @@map("strategic_alerts")
}

// =========================================
// 17. AUDIT & GOVERNANCE (Unchanged)
// =========================================

/// سجل الرقابة والحوكمة
model AuditLog {
  id        String   @id @default(cuid())
  entityId  String
  userId    String
  action    String
  details   String?
  oldData   String?
  newData   String?
  createdAt DateTime @default(now())

  entity    Entity   @relation(fields: [entityId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([entityId])
  @@index([userId])
  @@index([createdAt])
  @@map("audit_logs")
}
