{
  "name": "stratix-app",
  "version": "1.0.0",
  "description": "Stratix - Strategic Management Platform",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "build": "node scripts/railway-build.js",
    "build:local": "npx prisma generate && npx prisma db push",
    "postinstall": "npx prisma generate",
    "prisma:setup": "npx prisma generate && npx prisma db push",
    "seed": "node scripts/seed.js"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "express",
    "stratix",
    "strategy"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@prisma/client": "5.7.0",
    "bcryptjs": "2.4.3",
    "cors": "2.8.5",
    "dotenv": "16.3.1",
    "express": "4.18.2",
    "express-rate-limit": "^8.2.1",
    "express-validator": "^7.3.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "9.0.2",
    "mammoth": "^1.11.0",
    "multer": "^2.0.2",
    "prisma": "5.7.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "xlsx": "^0.18.5"
  },
  "prisma": {
    "schema": "prisma/schema.prisma"
  }
}