// =========================================
// STRATIX - Strategic Operating System
// Schema v3.0 — Simplified (20 Core Models)
// Date: February 20, 2026
// Strategy: Core models only, disabled models removed
// =========================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// =========================================
// 1. REFERENCE TABLES (Classification System)
// =========================================

/// القطاع (حكومي، خاص، غير ربحي)
model Sector {
  id        String   @id @default(cuid())
  nameAr    String   @unique
  nameEn    String   @unique
  code      String?  @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  entities   Entity[]
  industries Industry[]

  @@map("ref_sectors")
}

model Industry {
  id        String   @id @default(cuid())
  nameAr    String   @unique
  nameEn    String   @unique
  code      String?  @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  entities Entity[]
  sectors  Sector[]

  @@map("ref_industries")
}

/// نوع الكيان (مستشفى، وزارة، جمعية...)
model EntityType {
  id        String   @id @default(cuid())
  nameAr    String   @unique
  nameEn    String   @unique
  code      String?  @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  entities Entity[]

  @@map("ref_entity_types")
}

// =========================================
// 1b. SECTOR CONFIG (Industry Intelligence)
// تخصيص ذكي حسب القطاع التجاري
// =========================================

/// إعدادات القطاع — أسئلة مخصصة + معادلات Break-Even + متوسطات
model SectorConfig {
  id   String @id @default(cuid())
  code String @unique // CONSTRUCTION, RESTAURANT, RETAIL, etc.

  // الأسماء
  nameAr String // المقاولات والبناء
  nameEn String // Construction
  icon   String? // 🏗️
  color  String? // #f59e0b

  // الوحدة الأساسية للقطاع
  unitLabelAr String? // المشروع / المستخلص المالي
  unitLabelEn String? // Project / Financial Statement

  // أسئلة مخصصة لكل دور (JSON strings)
  cfoQuestions String? // أسئلة CFO المخصصة للقطاع
  cmoQuestions String? // أسئلة CMO
  cooQuestions String? // أسئلة COO

  // حساب نقطة التعادل (Break-Even)
  breakEvenFields String? // الحقول المطلوبة (JSON)
  formulas        String? // معادلات الحساب (JSON)
  benchmarks      String? // متوسطات القطاع (JSON)

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  entities Entity[]

  @@map("sector_configs")
}

// =========================================
// 2. COMPANY & SUBSCRIPTION (NEW — Evolution)
// =========================================

/// الشركة المشتركة في النظام (Tenant)
model Company {
  id      String  @id @default(cuid())
  nameAr  String
  nameEn  String?
  code    String? @unique
  logoUrl String?
  status  String  @default("ACTIVE") // ACTIVE, INACTIVE, TRIAL, SUSPENDED

  // بيانات التواصل
  email   String?
  phone   String?
  website String?

  // بيانات التعليق
  suspendedAt    DateTime?
  suspendReason  String?
  suspendedBy    String?   // ID المدير الذي علّق الحساب

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // العلاقات
  subscription Subscription?
  entities     Entity[]
  pattern      CompanyPattern?

  @@map("companies")
}

/// اشتراك الشركة في النظام
model Subscription {
  id          String    @id @default(cuid())
  companyId   String    @unique
  plan        String    @default("TRIAL") // TRIAL, BASIC, PRO, ENTERPRISE
  status      String    @default("ACTIVE") // ACTIVE, EXPIRED, CANCELLED
  startDate   DateTime  @default(now())
  endDate     DateTime?
  maxUsers    Int       @default(5)
  maxEntities Int       @default(1)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

// =========================================
// 3. IDENTITY CORE (Users & Entities)
// =========================================

/// User model
model User {
  id         String    @id @default(cuid())
  email      String    @unique
  password   String
  name       String
  phone      String?   @unique  // ✨ معرّف رئيسي — رقم الجوال
  phoneVerified Boolean @default(false) // ✨ هل تم التحقق من الجوال
  systemRole String    @default("USER") // SUPER_ADMIN, USER
  avatarUrl  String?
  lastLogin  DateTime? // آخر تسجيل دخول
  disabled   Boolean   @default(false) // تعطيل الحساب
  onboardingCompleted Boolean @default(false) // هل أكمل خطوات التأسيس

  // ✨ التحقق من الجوال (SMS)
  verificationCode   String?   // كود التحقق (6 أرقام)
  verificationExpiry DateTime? // صلاحية الكود

  // ✨ بيانات التشخيص (محفوظة من قبل التسجيل)
  diagnosticData String? // JSON: نتيجة التشخيص (مبتدئ أو ألم وطموح)
  userCategory   String? // INDIVIDUAL_DEV, INDIVIDUAL_IDEA, NEW_PROJECT, COMPANY_SMALL, COMPANY_MEDIUM, COMPANY_LARGE

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  memberships     Member[]
  auditLogs       AuditLog[]
  financialAudits FinancialAudit[]

  @@map("users")
}

/// Entity model - الكيان (المستشفى، الوزارة، الشركة...)
model Entity {
  id          String  @id @default(cuid())
  legalName   String
  displayName String?

  // 🔗 الربط بالشركة (Tenant)
  companyId String?

  // 🔗 الربط بشجرة التصنيف (اختياري)
  sectorId       String?
  industryId     String?
  typeId         String?
  sectorConfigId String? // ✨ ربط بالقطاع الذكي

  // ✨ حقول جديدة — Phase 1
  size    String? // MICRO, SMALL, MEDIUM, LARGE, ENTERPRISE
  school  String? // المدرسة الإدارية (BALANCED_SCORECARD, OKR, HOSHIN_KANRI, etc.)
  culture String? // الثقافة المؤسسية: AMERICAN, JAPANESE, EUROPEAN, ISLAMIC

  // ✨ السجل التجاري
  commercialRegNo String? @unique // رقم السجل التجاري — فريد لمنع التكرار

  logoUrl   String?
  metadata  String? // JSON field for extra data (pain/ambition, preferences, etc.)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // العلاقات
  company      Company?      @relation(fields: [companyId], references: [id], onDelete: SetNull)
  sector       Sector?       @relation(fields: [sectorId], references: [id], onDelete: SetNull)
  industry     Industry?     @relation(fields: [industryId], references: [id], onDelete: SetNull)
  entityType   EntityType?   @relation(fields: [typeId], references: [id], onDelete: SetNull)
  sectorConfig SectorConfig? @relation(fields: [sectorConfigId], references: [id], onDelete: SetNull)

  // العلاقات مع النظام
  members            Member[]
  strategyVersions   StrategyVersion[]
  assessments        Assessment[]
  auditLogs          AuditLog[]
  stakeholders       Stakeholder[] // ✨ أصحاب المصلحة
  financialDecisions FinancialDecision[] // ✨ القرارات المالية
  integrations       Integration[] // ✨ التكاملات
  departments        Department[] // ✨ الأقسام
  invitations        Invitation[] // ✨ الدعوات

  @@index([companyId])
  @@index([sectorId])
  @@index([industryId])
  @@index([typeId])
  @@index([sectorConfigId])
  @@map("entities")
}

/// Member model - ربط User و Entity مع الأدوار
model Member {
  id       String   @id @default(cuid())
  userId   String
  entityId String
  role     String   @default("VIEWER") // OWNER, ADMIN, EDITOR, VIEWER, DATA_ENTRY
  userType String   @default("EXPLORER") // EXPLORER, COMPANY_MANAGER, DEPT_MANAGER, CONSULTANT
  joinedAt DateTime @default(now())

  // ✨ Phase 0 — الفريق الاستراتيجي
  departmentRole String? // CEO, CFO, CMO, COO, CTO, CHRO, CSO, CCO, CLO
  departmentId   String?
  department     Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  invitedBy      String? // userId اللي أرسل الدعوة

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  entity Entity @relation(fields: [entityId], references: [id], onDelete: Cascade)

  @@unique([userId, entityId])
  @@index([userId])
  @@index([entityId])
  @@index([departmentId])
  @@map("members")
}

/// Department model - الأقسام/الإدارات داخل الكيان
model Department {
  id       String @id @default(cuid())
  entityId String
  name     String // "المالية", "التسويق", "العمليات"
  code     String // FINANCE, MARKETING, OPERATIONS, HR, TECH, SALES, SUPPORT, LEGAL
  icon     String? // bi-cash-coin, bi-megaphone, etc.
  color    String? // لون البطاقة

  // حالة بيانات القسم
  dataStatus  String @default("EMPTY") // EMPTY, IN_PROGRESS, COMPLETED
  dataPercent Int    @default(0) // 0-100 نسبة الإكمال
  dataSummary String? // JSON — ملخص ما ملأه القسم

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  entity          Entity             @relation(fields: [entityId], references: [id], onDelete: Cascade)
  members         Member[]
  financialAudits FinancialAudit[]

  @@unique([entityId, code])
  @@index([entityId])
  @@map("departments")
}

/// Invitation model - دعوات الانضمام للفريق
model Invitation {
  id             String   @id @default(cuid())
  entityId       String
  email          String
  name           String? // اسم المدعو
  departmentRole String  // CEO, CFO, CMO, COO, CTO, CHRO, CSO, CCO, CLO
  role           String   @default("EDITOR") // الصلاحية المبدئية
  token          String   @unique @default(cuid()) // رابط الدعوة الفريد
  status         String   @default("PENDING") // PENDING, ACCEPTED, EXPIRED, CANCELLED
  invitedBy      String  // userId اللي أرسل الدعوة
  message        String? // رسالة شخصية مع الدعوة
  expiresAt      DateTime
  acceptedAt     DateTime?
  createdAt      DateTime @default(now())

  entity Entity @relation(fields: [entityId], references: [id], onDelete: Cascade)

  @@unique([entityId, email])
  @@index([token])
  @@index([entityId])
  @@index([status])
  @@map("invitations")
}

// DataEntryPermission — DISABLED (removed for simplification)

// =========================================
// 3. STRATEGY FOUNDATION
// =========================================

/// نسخة الاستراتيجية — القلب الرئيسي للنظام
model StrategyVersion {
  id            String @id @default(cuid())
  entityId      String
  versionNumber Int
  status        String @default("DRAFT") // DRAFT, ACTIVE, ARCHIVED, PENDING

  // ✨ حقول جديدة — Phase 1
  name        String? // اسم وصفي: "خطة 2024"، "سيناريو التحول الرقمي"
  description String? // وصف مختصر للنسخة
  isActive    Boolean   @default(false) // نسخة واحدة فقط نشطة لكل كيان
  createdBy   String? // ID المستخدم الذي أنشأها
  approvedBy  String? // ID المستخدم الذي اعتمدها
  approvedAt  DateTime? // تاريخ الاعتماد

  // 🔗 Linked List - تتبع عمليات Pivot
  pivotedFromId String?
  createdAt     DateTime  @default(now())
  activatedAt   DateTime?
  updatedAt     DateTime  @updatedAt

  entity       Entity            @relation(fields: [entityId], references: [id], onDelete: Cascade)
  prevVersion  StrategyVersion?  @relation("VersionLineage", fields: [pivotedFromId], references: [id])
  nextVersions StrategyVersion[] @relation("VersionLineage")

  // العلاقات الاستراتيجية
  directions         StrategicDirection[] // ✨ جديد — الهرم الاستراتيجي
  externalAnalyses   ExternalAnalysis[] // ✨ جديد — PESTEL + Porter
  objectives         StrategicObjective[]
  kpis               KPI[]
  initiatives        StrategicInitiative[]
  reviews            StrategicReview[]
  choices            StrategicChoice[]
  risks              StrategicRisk[]
  scenarios          Scenario[] // ✨ سيناريوهات المحاكاة
  companyAnalyses    CompanyAnalysis[] // تحليلات الأدوات
  financialDecisions FinancialDecision[] // ✨ القرارات المالية

  @@unique([entityId, versionNumber])
  @@index([entityId])
  @@index([pivotedFromId])
  @@map("strategy_versions")
}

// =========================================
// 4. STRATEGIC DIRECTION (NEW ✨)
// رؤية، رسالة، قيم، قضايا كبرى
// =========================================

/// الاتجاه الاستراتيجي (الهرم الاستراتيجي)
model StrategicDirection {
  id        String   @id @default(cuid())
  versionId String
  type      String // VISION, MISSION, VALUES, ISSUES, LONG_TERM_GOALS
  content   String // النص الكامل
  order     Int      @default(0) // الترتيب (مهم للقيم المتعددة)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  version StrategyVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)

  @@index([versionId])
  @@index([type])
  @@map("strategic_directions")
}

// =========================================
// 5. EXTERNAL ANALYSIS (NEW ✨)
// PESTEL + Porter's Five Forces
// =========================================

/// التحليل الخارجي
model ExternalAnalysis {
  id          String   @id @default(cuid())
  versionId   String
  type        String // POLITICAL, ECONOMIC, SOCIAL, TECHNOLOGICAL, ENVIRONMENTAL, LEGAL,
  // PORTER_RIVALRY, PORTER_NEW_ENTRANTS, PORTER_SUBSTITUTES, PORTER_SUPPLIERS, PORTER_BUYERS
  factor      String // العامل (مثال: "تغيير سياسة الضرائب")
  impact      String   @default("MEDIUM") // HIGH, MEDIUM, LOW
  probability Float? // 0-1 احتمالية التأثير
  trend       String? // INCREASING, STABLE, DECREASING — اتجاه العامل
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  version StrategyVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)

  @@index([versionId])
  @@index([type])
  @@map("external_analyses")
}

// =========================================
// 6. STRATEGIC OBJECTIVES & KPIs (ENHANCED ✨)
// BSC + OKR Support
// =========================================

/// الأهداف الاستراتيجية — محسّنة مع BSC + OKR
model StrategicObjective {
  id          String  @id @default(cuid())
  versionId   String
  title       String
  description String?
  status      String  @default("DRAFT")

  // ✨ حقول جديدة — Phase 1
  parentId      String? // 🔗 OKR Hierarchy — الهدف الأب
  perspective   String? // BSC: FINANCIAL, CUSTOMER, INTERNAL_PROCESS, LEARNING_GROWTH
  weight        Float?    @default(1.0) // أهمية نسبية
  baselineValue Float? // القيمة الأساسية (خط الأساس)
  targetValue   Float? // القيمة المستهدفة
  deadline      DateTime? // الموعد النهائي
  ownerId       String? // مسؤول الهدف (Member ID)

  // ✨ حقول جديدة — Phase 3 (OKR)
  framework String? @default("BSC") // BSC, OKR, BOTH
  progress  Float?  @default(0) // 0-100 % تقدم (للـ OKR)
  quarter   String? // Q1, Q2, Q3, Q4 — لفلترة OKR

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  version  StrategyVersion      @relation(fields: [versionId], references: [id], onDelete: Cascade)
  parent   StrategicObjective?  @relation("ObjectiveHierarchy", fields: [parentId], references: [id])
  children StrategicObjective[] @relation("ObjectiveHierarchy")
  kpis     KPI[]

  @@index([versionId])
  @@index([parentId])
  @@map("strategic_objectives")
}

/// مؤشرات الأداء (KPI) — محسّنة
model KPI {
  id          String  @id @default(cuid())
  versionId   String
  objectiveId String?
  name        String
  nameAr      String?
  description String?
  target      Float
  actual      Float?
  unit        String  @default("%")
  status      String  @default("ON_TRACK") // ON_TRACK, AT_RISK, OFF_TRACK, ACHIEVED

  // ✨ حقول جديدة — Phase 1
  formula           String? // صيغة الحساب (مثال: "Revenue / Employees")
  dataSource        String? // مصدر البيانات (مثال: "ERP System", "Manual Entry")
  frequency         String? @default("MONTHLY") // DAILY, WEEKLY, MONTHLY, QUARTERLY, YEARLY
  warningThreshold  Float? // نسبة مئوية: تنبيه عند < هذه القيمة (مثال: 0.8 = 80%)
  criticalThreshold Float? // نسبة مئوية: خطر عند < هذه القيمة (مثال: 0.5 = 50%)

  // ✨ حقول جديدة — Phase B (BSC + Leading/Lagging)
  kpiType        String? // LEADING, LAGGING — تصنيف المؤشر
  bscPerspective String? // FINANCIAL, CUSTOMER, INTERNAL_PROCESS, LEARNING_GROWTH — بُعد BSC
  direction      String  @default("HIGHER_IS_BETTER") // HIGHER_IS_BETTER أو LOWER_IS_BETTER — اتجاه المؤشر

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  version   StrategyVersion     @relation(fields: [versionId], references: [id], onDelete: Cascade)
  objective StrategicObjective? @relation(fields: [objectiveId], references: [id], onDelete: SetNull)

  entries   KPIEntry[] // ✨ جديد — إدخال البيانات الدوري
  diagnoses KpiDiagnosis[]

  @@index([versionId])
  @@index([objectiveId])
  @@map("kpis")
}

// =========================================
// 7. KPI DATA ENTRY (NEW ✨)
// إدخال القيم الفعلية دورياً
// =========================================

/// إدخالات الأداء — سجل تاريخي لقيم KPI
model KPIEntry {
  id          String   @id @default(cuid())
  kpiId       String
  value       Float // القيمة الفعلية
  periodStart DateTime // بداية الفترة
  periodEnd   DateTime // نهاية الفترة
  enteredBy   String? // ID المستخدم الذي أدخل البيانات
  status      String   @default("CONFIRMED") // DRAFT, CONFIRMED
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  kpi KPI @relation(fields: [kpiId], references: [id], onDelete: Cascade)

  @@index([kpiId])
  @@index([periodStart])
  @@map("kpi_entries")
}

// =========================================
// 8. STRATEGIC INITIATIVES (ENHANCED ✨)
// =========================================

/// المبادرات الاستراتيجية — محسّنة
model StrategicInitiative {
  id          String  @id @default(cuid())
  versionId   String
  title       String
  description String?
  owner       String?
  status      String  @default("PLANNED") // PLANNED, IN_PROGRESS, COMPLETED, CANCELLED, ON_HOLD

  // ✨ حقول جديدة — Phase 1
  startDate DateTime? // تاريخ البداية
  endDate   DateTime? // تاريخ النهاية
  progress  Float?    @default(0) // 0-100 نسبة الإنجاز
  budget    Float? // الميزانية المخصصة
  kpiId     String? // ربط بمؤشر الأداء المستهدف
  priority  String?   @default("MEDIUM") // HIGH, MEDIUM, LOW

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // ✨ حقول auto-initiative (من company-pattern)
  category    String? // financial_rescue, organization, sales, automation
  autoCreated Boolean @default(false) // أُنشئت تلقائياً من نمط الشركة
  budgetSpent Float?  @default(0)

  version    StrategyVersion  @relation(fields: [versionId], references: [id], onDelete: Cascade)
  tasks      InitiativeTask[]
  kpis       InitiativeKpi[]
  milestones Milestone[]
  raciEntries RaciEntry[]

  @@index([versionId])
  @@map("strategic_initiatives")
}

model InitiativeTask {
  id           String    @id @default(cuid())
  initiativeId String
  title        String
  status       String    @default("PENDING") // PENDING, ACTIVE, COMPLETED
  dueDate      DateTime?
  order        Int       @default(0)
  createdAt    DateTime  @default(now())

  initiative StrategicInitiative @relation(fields: [initiativeId], references: [id], onDelete: Cascade)

  @@index([initiativeId])
  @@map("initiative_tasks")
}

model InitiativeKpi {
  id           String   @id @default(cuid())
  initiativeId String
  name         String
  target       Float
  current      Float    @default(0)
  unit         String?
  createdAt    DateTime @default(now())

  initiative StrategicInitiative @relation(fields: [initiativeId], references: [id], onDelete: Cascade)

  @@index([initiativeId])
  @@map("initiative_kpis")
}

// =========================================
// 9. STRATEGIC REVIEWS (ENHANCED ✨)
// =========================================

/// المراجعات الاستراتيجية — محسّنة مع محرك القرارات
model StrategicReview {
  id         String   @id @default(cuid())
  versionId  String
  title      String
  reviewDate DateTime
  status     String   @default("PENDING") // PENDING, IN_PROGRESS, COMPLETED
  notes      String?

  // ✨ حقول جديدة — Phase 1
  type            String? @default("QUARTERLY_REVIEW") // QUARTERLY_REVIEW, ANNUAL_REVIEW, AD_HOC, AUDIT
  decision        String? // CONTINUE, ADJUST, PIVOT — محرك القرارات
  summary         String? // ملخص تنفيذي
  findings        String? // النتائج والملاحظات
  recommendations String? // التوصيات
  overallScore    Float? // متوسط أداء النسخة (0-100)
  conductedBy     String? // المراجع

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  version StrategyVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)

  @@index([versionId])
  @@map("strategic_reviews")
}

// =========================================
// 10. ASSESSMENTS (Unchanged)
// =========================================

/// التقييمات الاستراتيجية
model Assessment {
  id          String   @id @default(cuid())
  entityId    String
  title       String
  description String?
  status      String   @default("DRAFT")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  entity         Entity          @relation(fields: [entityId], references: [id], onDelete: Cascade)
  dimensions     Dimension[]
  analysisPoints AnalysisPoint[]
  towsStrategies TOWSStrategy[]

  @@index([entityId])
  @@map("assessments")
}

/// أبعاد التقييم
model Dimension {
  id           String   @id @default(cuid())
  assessmentId String
  name         String
  description  String?
  weight       Float    @default(1.0) // ✨ أهمية البعد (0.5 - 5.0)
  orderIndex   Int      @default(0) // ✨ ترتيب البعد
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  assessment Assessment  @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  criteria   Criterion[]

  @@index([assessmentId])
  @@map("dimensions")
}

/// معايير التقييم
model Criterion {
  id          String   @id @default(cuid())
  dimensionId String
  name        String
  description String?
  score       Float?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  dimension Dimension @relation(fields: [dimensionId], references: [id], onDelete: Cascade)

  @@index([dimensionId])
  @@map("criteria")
}

// =========================================
// 11. STRATEGIC CHOICES & RISKS (ENHANCED ✨)
// =========================================

/// الخيارات الاستراتيجية — محسّنة مع Ansoff + Porter
model StrategicChoice {
  id          String  @id @default(cuid())
  versionId   String
  title       String
  description String?
  status      String  @default("ACTIVE") // ACTIVE, COMPLETED, DROPPED
  priority    String  @default("MEDIUM") // HIGH, MEDIUM, LOW

  // ✨ حقول جديدة — Phase 1
  choiceType           String? // MARKET_PENETRATION, MARKET_DEVELOPMENT, PRODUCT_DEVELOPMENT,
  // DIVERSIFICATION, COST_LEADERSHIP, DIFFERENTIATION, FOCUS, BEST_COST
  marketAttractiveness Int? // 1-5 جاذبية السوق
  competitiveAdvantage Int? // 1-5 الميزة التنافسية
  feasibility          Int? // 1-5 قابلية التنفيذ
  riskLevel            String? @default("MEDIUM") // HIGH, MEDIUM, LOW
  isSelected           Boolean @default(false) // هل تم اختياره كخيار معتمد؟
  requiredCapabilities String? // القدرات المطلوبة

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  version StrategyVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)
  risks   StrategicRisk[]

  @@index([versionId])
  @@map("strategic_choices")
}

/// المخاطر الاستراتيجية — محسّنة مع تقييم كمّي
model StrategicRisk {
  id          String  @id @default(cuid())
  choiceId    String?
  versionId   String
  title       String
  description String?
  probability String  @default("MEDIUM") // الاحتمالية النوعية (للتوافق مع البيانات القديمة)
  impact      String  @default("MEDIUM") // الأثر النوعي
  mitigation  String?
  owner       String?
  status      String  @default("OPEN") // OPEN, MITIGATED, CLOSED, IDENTIFIED, ASSESSING, MONITORING

  // ✨ حقول جديدة — Phase 1
  category         String? // STRATEGIC, OPERATIONAL, FINANCIAL, COMPLIANCE, REPUTATIONAL
  probabilityScore Int? // 1-5 الاحتمالية الكمّية
  impactScore      Int? // 1-5 الأثر الكمّي
  riskScore        Int? // probability * impact (محسوب تلقائياً)
  contingency      String? // خطة الطوارئ

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  choice       StrategicChoice?  @relation(fields: [choiceId], references: [id], onDelete: SetNull)
  version      StrategyVersion   @relation(fields: [versionId], references: [id], onDelete: Cascade)
  stakeholders StakeholderRisk[] // ✨ جديد — ربط بأصحاب المصلحة

  @@index([choiceId])
  @@index([versionId])
  @@map("strategic_risks")
}

// =========================================
// 11b. STAKEHOLDERS & STAKEHOLDER-RISK LINK (NEW ✨)
// أصحاب المصلحة وربطهم بالمخاطر
// =========================================

/// أصحاب المصلحة — تحليل القوة والاهتمام
model Stakeholder {
  id       String @id @default(cuid())
  entityId String

  // البيانات الأساسية
  name String // الاسم (مجلس الإدارة، الموظفون...)
  role String? // الدور/العلاقة
  type String  @default("EXTERNAL") // INTERNAL, EXTERNAL, REGULATOR, PARTNER, COMPETITOR, COMMUNITY

  // مصفوفة القوة/الاهتمام (1-5)
  influence Int    @default(3) // 1-5 مستوى القوة/التأثير
  interest  Int    @default(3) // 1-5 مستوى الاهتمام
  strategy  String @default("inform") // manage, satisfy, inform, monitor

  // المشاعر والمشاركة
  position   String @default("NEUTRAL") // SUPPORTIVE, NEUTRAL, RESISTANT
  engagement Int    @default(50) // 0-100 نسبة المشاركة

  // التواصل
  needs         String? // احتياجات صاحب المصلحة
  expectations  String? // توقعات صاحب المصلحة
  contactInfo   String? // بيانات التواصل
  lastContactAt DateTime?
  meetingsCount Int       @default(0)

  // المظهر
  color String? // لون البطاقة

  // Metadata
  createdBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  entity Entity            @relation(fields: [entityId], references: [id], onDelete: Cascade)
  risks  StakeholderRisk[] // المخاطر المرتبطة

  @@index([entityId])
  @@index([type])
  @@index([strategy])
  @@map("stakeholders")
}

/// جدول الربط: أصحاب المصلحة × المخاطر (Many-to-Many)
model StakeholderRisk {
  id            String   @id @default(cuid())
  stakeholderId String
  riskId        String
  impactLevel   String   @default("MEDIUM") // HIGH, MEDIUM, LOW
  impactType    String? // AFFECTED_BY, CAUSES, MITIGATES
  notes         String?
  createdAt     DateTime @default(now())

  stakeholder Stakeholder   @relation(fields: [stakeholderId], references: [id], onDelete: Cascade)
  risk        StrategicRisk @relation(fields: [riskId], references: [id], onDelete: Cascade)

  @@unique([stakeholderId, riskId])
  @@index([stakeholderId])
  @@index([riskId])
  @@map("stakeholder_risks")
}

// =========================================
// 12. CORRECTIONS & DIAGNOSES
// =========================================

/// تشخيص سبب ضعف مؤشر الأداء
model KpiDiagnosis {
  id        String   @id @default(cuid())
  kpiId     String
  diagnosis String
  severity  String   @default("MEDIUM") // HIGH, MEDIUM, LOW
  rootCause String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  kpi         KPI                @relation(fields: [kpiId], references: [id], onDelete: Cascade)
  corrections CorrectionAction[]

  @@index([kpiId])
  @@map("kpi_diagnoses")
}

/// الإجراء التصحيحي المرتبط بتشخيص
model CorrectionAction {
  id              String    @id @default(cuid())
  diagnosisId     String
  title           String
  description     String?
  assignee        String?
  status          String    @default("PENDING") // PENDING, IN_PROGRESS, COMPLETED
  dueDate         DateTime?
  completedAt     DateTime?
  analysisPointId String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  diagnosis     KpiDiagnosis   @relation(fields: [diagnosisId], references: [id], onDelete: Cascade)
