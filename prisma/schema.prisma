// =========================================
// STRATIX - Updated Schema with Hybrid Model
// Date: February 16, 2026
// Combining: Reference Tables + Member Model + Audit Log + Strategic Features
// =========================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// =========================================
// 1. ENUMS
// =========================================

// Enums removed for SQLite compatibility; using string fields with defaults instead

// =========================================
// 2. REFERENCE TABLES (Classification System)
// =========================================

/// القطاع (حكومي، خاص، غير ربحي)
model Sector {
  id        String     @id @default(cuid())
  nameAr    String     @unique
  nameEn    String     @unique
  code      String?    @unique
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  
  entities  Entity[]

  @@map("ref_sectors")
}

/// النشاط الاقتصادي (صحي، تعليمي، صناعي...)
model Industry {
  id        String     @id @default(cuid())
  nameAr    String     @unique
  nameEn    String     @unique
  code      String?    @unique
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  entities  Entity[]

  @@map("ref_industries")
}

/// نوع الكيان (مستشفى، وزارة، جمعية...)
model EntityType {
  id        String     @id @default(cuid())
  nameAr    String     @unique
  nameEn    String     @unique
  code      String?    @unique
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  entities  Entity[]

  @@map("ref_entity_types")
}

// =========================================
// 3. IDENTITY CORE (Users & Entities)
// =========================================

/// User model - بسيط (بدون entity مباشر)
model User {
  id        String    @id @default(cuid())
  email     String    @unique
  password  String
  name      String
  avatarUrl String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  // علاقات
  memberships Member[]
  auditLogs   AuditLog[]

  @@map("users")
}

/// Entity model - الكيان (المستشفى، الوزارة، الشركة...)
model Entity {
  id          String   @id @default(cuid())
  legalName   String   // الاسم الرسمي (إلزامي)
  displayName String?  // الاسم المختصر
  
  // 🔗 الربط بشجرة التصنيف (اختياري)
  sectorId    String?
  industryId  String?
  typeId      String?
  
  logoUrl     String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // العلاقات مع التصنيفات
  sector      Sector?     @relation(fields: [sectorId], references: [id], onDelete: SetNull)
  industry    Industry?   @relation(fields: [industryId], references: [id], onDelete: SetNull)
  entityType  EntityType? @relation(fields: [typeId], references: [id], onDelete: SetNull)

  // العلاقات مع النظام
  members             Member[]
  strategyVersions    StrategyVersion[]
  assessments         Assessment[]
  auditLogs           AuditLog[]

  @@index([sectorId])
  @@index([industryId])
  @@index([typeId])
  @@map("entities")
}

/// Member model - ربط User و Entity مع الأدوار
model Member {
  id        String   @id @default(cuid())
  userId    String
  entityId  String
  role      String   @default("VIEWER")
  joinedAt  DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  entity    Entity   @relation(fields: [entityId], references: [id], onDelete: Cascade)

  @@unique([userId, entityId]) // المستخدم لا يتكرر في نفس الكيان
  @@index([userId])
  @@index([entityId])
  @@map("members")
}

// =========================================
// 4. STRATEGY FOUNDATION
// =========================================

/// نسخة الاستراتيجية مع تتبع التطور التاريخي
model StrategyVersion {
  id              String    @id @default(cuid())
  entityId        String
  versionNumber   Int
  status          String    @default("DRAFT")
  
  // 🔗 Linked List - تتبع عمليات Pivot
  pivotedFromId   String?
  createdAt       DateTime  @default(now())
  activatedAt     DateTime?
  updatedAt       DateTime  @updatedAt

  entity          Entity    @relation(fields: [entityId], references: [id], onDelete: Cascade)
  prevVersion     StrategyVersion? @relation("VersionLineage", fields: [pivotedFromId], references: [id])
  nextVersions    StrategyVersion[] @relation("VersionLineage")
  
  // علاقات مع الأهداف والمؤشرات
  objectives      StrategicObjective[]
  kpis            KPI[]
  initiatives     StrategicInitiative[]
  reviews         StrategicReview[]

  @@unique([entityId, versionNumber])
  @@index([entityId])
  @@index([pivotedFromId])
  @@map("strategy_versions")
}

/// الأهداف الاستراتيجية
model StrategicObjective {
  id          String    @id @default(cuid())
  versionId   String
  title       String
  description String?
  status      String    @default("DRAFT")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  version     StrategyVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)
  kpis        KPI[]

  @@index([versionId])
  @@map("strategic_objectives")
}

/// مؤشرات الأداء (KPI)
model KPI {
  id          String    @id @default(cuid())
  versionId   String
  objectiveId String?
  name        String
  nameAr      String?
  description String?
  target      Float
  actual      Float?
  unit        String    @default("%")
  status      String    @default("ON_TRACK")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  version     StrategyVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)
  objective   StrategicObjective? @relation(fields: [objectiveId], references: [id], onDelete: SetNull)

  @@index([versionId])
  @@index([objectiveId])
  @@map("kpis")
}

/// المبادرات الاستراتيجية
model StrategicInitiative {
  id          String    @id @default(cuid())
  versionId   String
  title       String
  description String?
  owner       String?
  status      String    @default("PLANNED")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  version     StrategyVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)

  @@index([versionId])
  @@map("strategic_initiatives")
}

/// المراجعات الاستراتيجية
model StrategicReview {
  id          String    @id @default(cuid())
  versionId   String
  title       String
  reviewDate  DateTime
  status      String    @default("PENDING")
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  version     StrategyVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)

  @@index([versionId])
  @@map("strategic_reviews")
}

// =========================================
// 5. ASSESSMENTS
// =========================================

/// التقييمات الاستراتيجية
model Assessment {
  id          String    @id @default(cuid())
  entityId    String
  title       String
  description String?
  status      String    @default("DRAFT")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  entity      Entity    @relation(fields: [entityId], references: [id], onDelete: Cascade)
  dimensions  Dimension[]

  @@index([entityId])
  @@map("assessments")
}

/// أبعاد التقييم
model Dimension {
  id            String    @id @default(cuid())
  assessmentId  String
  name          String
  description   String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  assessment    Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  criteria      Criterion[]

  @@index([assessmentId])
  @@map("dimensions")
}

/// معايير التقييم
model Criterion {
  id          String    @id @default(cuid())
  dimensionId String
  name        String
  description String?
  score       Float?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  dimension   Dimension @relation(fields: [dimensionId], references: [id], onDelete: Cascade)

  @@index([dimensionId])
  @@map("criteria")
}

// =========================================
// 6. AUDIT & GOVERNANCE
// =========================================

/// سجل الرقابة والحوكمة
model AuditLog {
  id        String   @id @default(cuid())
  entityId  String
  userId    String
  action    String   // 'STRATEGY_PIVOT', 'ENTITY_UPDATE', 'MEMBER_ADDED'
  details   String?
  oldData   String?  // JSON as string
  newData   String?  // JSON as string
  createdAt DateTime @default(now())

  entity    Entity   @relation(fields: [entityId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([entityId])
  @@index([userId])
  @@index([createdAt])
  @@map("audit_logs")
}
