generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

/// القطاع (حكومي، خاص، غير ربحي)
model Sector {
  id         String     @id @default(cuid())
  nameAr     String     @unique
  nameEn     String     @unique
  code       String?    @unique
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  entities   Entity[]
  industries Industry[] @relation("IndustryToSector")

  @@map("ref_sectors")
}

model Industry {
  id        String   @id @default(cuid())
  nameAr    String   @unique
  nameEn    String   @unique
  code      String?  @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  entities  Entity[]
  sectors   Sector[] @relation("IndustryToSector")

  @@map("ref_industries")
}

/// نوع الكيان (مستشفى، وزارة، جمعية...)
model EntityType {
  id        String   @id @default(cuid())
  nameAr    String   @unique
  nameEn    String   @unique
  code      String?  @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  entities  Entity[]

  @@map("ref_entity_types")
}

/// إعدادات القطاع — أسئلة مخصصة + معادلات Break-Even + متوسطات
model SectorConfig {
  id              String   @id @default(cuid())
  code            String   @unique
  nameAr          String
  nameEn          String
  icon            String?
  color           String?
  unitLabelAr     String?
  unitLabelEn     String?
  cfoQuestions    String?
  cmoQuestions    String?
  cooQuestions    String?
  breakEvenFields String?
  formulas        String?
  benchmarks      String?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  entities        Entity[]

  @@map("sector_configs")
}

/// الشركة المشتركة في النظام (Tenant)
model Company {
  id            String          @id @default(cuid())
  nameAr        String
  nameEn        String?
  code          String?         @unique
  logoUrl       String?
  status        String          @default("ACTIVE")
  email         String?
  phone         String?
  website       String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  suspendReason String?
  suspendedAt   DateTime?
  suspendedBy   String?
  pattern       CompanyPattern?
  entities      Entity[]
  subscription  Subscription?

  @@map("companies")
}

/// اشتراك الشركة في النظام
model Subscription {
  id          String    @id @default(cuid())
  companyId   String    @unique
  plan        String    @default("TRIAL")
  status      String    @default("ACTIVE")
  startDate   DateTime  @default(now())
  endDate     DateTime?
  maxUsers    Int       @default(5)
  maxEntities Int       @default(1)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  company     Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

/// User model
model User {
  id                  String                @id @default(cuid())
  email               String                @unique
  password            String
  name                String
  phone               String?               @unique
  phoneVerified       Boolean               @default(false)
  systemRole          String                @default("USER")
  avatarUrl           String?
  lastLogin           DateTime?
  disabled            Boolean               @default(false)
  onboardingCompleted Boolean               @default(false)
  verificationCode    String?
  verificationExpiry  DateTime?
  diagnosticData      String?
  userCategory        String?
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
  auditLogs           AuditLog[]
  healthReports       CompanyHealthReport[] @relation("HealthReporter")
  financialAudits     FinancialAudit[]
  createdIssues       Issue[]               @relation("createdIssues")
  assignedIssues      Issue[]               @relation("assignedIssues")
  memberships         Member[]
  resourceAccess      ResourceAccess[]

  @@map("users")
}

/// Entity model - الكيان (المستشفى، الوزارة، الشركة...)
model Entity {
  id                 String                @id @default(cuid())
  legalName          String
  displayName        String?
  companyId          String?
  sectorId           String?
  industryId         String?
  typeId             String?
  sectorConfigId     String?
  size               String?
  school             String?
  culture            String?
  commercialRegNo    String?               @unique
  logoUrl            String?
  metadata           String?
  isActive           Boolean               @default(true)
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt
  assessments        Assessment[]
  auditLogs          AuditLog[]
  dimensions         CompanyDimension?     @relation("EntityDimensions")
  healthReports      CompanyHealthReport[]
  departments        Department[]
  employees          Employee[]
  sectorConfig       SectorConfig?         @relation(fields: [sectorConfigId], references: [id])
  entityType         EntityType?           @relation(fields: [typeId], references: [id])
  industry           Industry?             @relation(fields: [industryId], references: [id])
  sector             Sector?               @relation(fields: [sectorId], references: [id])
  company            Company?              @relation(fields: [companyId], references: [id])
  financialDecisions FinancialDecision[]
  govPlatforms       GovPlatformStatus[]
  housingUnits       HousingUnit[]
  integrations       Integration[]
  invitations        Invitation[]
  issues             Issue[]
  members            Member[]
  stakeholders       Stakeholder[]
  strategyVersions   StrategyVersion[]
  webhooks           Webhook[]             @relation("EntityWebhooks")

  @@index([companyId])
  @@index([sectorId])
  @@index([industryId])
  @@index([typeId])
  @@index([sectorConfigId])
  @@map("entities")
}

/// Member model - ربط User و Entity مع الأدوار
model Member {
  id             String      @id @default(cuid())
  userId         String
  entityId       String
  role           String      @default("VIEWER")
  userType       String      @default("EXPLORER")
  joinedAt       DateTime    @default(now())
  departmentRole String?
  departmentId   String?
  invitedBy      String?
  entity         Entity      @relation(fields: [entityId], references: [id], onDelete: Cascade)
  user           User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  department     Department? @relation(fields: [departmentId], references: [id])

  @@unique([userId, entityId])
  @@index([userId])
  @@index([entityId])
  @@index([departmentId])
  @@map("members")
}

/// Department model - الأقسام/الإدارات داخل الكيان
model Department {
  id              String           @id @default(cuid())
  entityId        String
  name            String
  code            String
  icon            String?
  color           String?
  dataStatus      String           @default("EMPTY")
  dataPercent     Int              @default(0)
  dataSummary     String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  entity          Entity           @relation(fields: [entityId], references: [id], onDelete: Cascade)
  financialAudits FinancialAudit[]
  members         Member[]

  @@unique([entityId, code])
  @@index([entityId])
  @@map("departments")
}

/// تقييم صحة الإدارة (Dept Health)
model DepartmentHealth {
  id            String   @id @default(cuid())
  entityId      String
  departmentKey String
  skills        String?
  processes     String?
  culture       String?
  resources     String?
  satisfaction  String?
  productivity  String?
  updatedAt     DateTime @updatedAt
  createdAt     DateTime @default(now())

  @@unique([entityId, departmentKey])
  @@index([entityId])
  @@map("dept_health")
}

/// السيناريوهات الاستراتيجية (Scenarios)
model DepartmentScenario {
  id            String   @id @default(cuid())
  entityId      String
  departmentKey String
  optimistic    String?
  realistic     String?
  pessimistic   String?
  updatedAt     DateTime @updatedAt
  createdAt     DateTime @default(now())

  @@unique([entityId, departmentKey])
  @@index([entityId])
  @@map("dept_scenarios")
}

/// الأهداف والنتائج الرئيسية (OKRs)
model DepartmentObjective {
  id            String      @id @default(cuid())
  entityId      String
  departmentKey String
  title         String
  description   String?
  updatedAt     DateTime    @updatedAt
  createdAt     DateTime    @default(now())
  keyResults    KeyResult[]

  @@index([entityId])
  @@map("dept_objectives")
}

model KeyResult {
  id           String              @id @default(cuid())
  objectiveId  String
  title        String
  targetValue  String?
  currentValue String?
  objective    DepartmentObjective @relation(fields: [objectiveId], references: [id], onDelete: Cascade)

  @@index([objectiveId])
  @@map("dept_key_results")
}

/// Invitation model - دعوات الانضمام للفريق
model Invitation {
  id             String    @id @default(cuid())
  entityId       String
  email          String
  name           String?
  departmentRole String
  role           String    @default("EDITOR")
  token          String    @unique @default(cuid())
  status         String    @default("PENDING")
  invitedBy      String
  message        String?
  expiresAt      DateTime
  acceptedAt     DateTime?
  createdAt      DateTime  @default(now())
  entity         Entity    @relation(fields: [entityId], references: [id], onDelete: Cascade)

  @@unique([entityId, email])
  @@index([token])
  @@index([entityId])
  @@index([status])
  @@map("invitations")
}

/// نسخة الاستراتيجية — القلب الرئيسي للنظام
model StrategyVersion {
  id                 String                @id @default(cuid())
  entityId           String
  versionNumber      Int
  status             String                @default("DRAFT")
  name               String?
  description        String?
  isActive           Boolean               @default(false)
  createdBy          String?
  approvedBy         String?
  approvedAt         DateTime?
  pivotedFromId      String?
  createdAt          DateTime              @default(now())
  activatedAt        DateTime?
  updatedAt          DateTime              @updatedAt
  companyAnalyses    CompanyAnalysis[]
  externalAnalyses   ExternalAnalysis[]
  financialDecisions FinancialDecision[]
  kpis               KPI[]
  scenarios          Scenario[]
  choices            StrategicChoice[]
  directions         StrategicDirection[]
  initiatives        StrategicInitiative[]
  objectives         StrategicObjective[]
  projects           StrategicProject[]
  reviews            StrategicReview[]
  risks              StrategicRisk[]
  prevVersion        StrategyVersion?      @relation("VersionLineage", fields: [pivotedFromId], references: [id])
  nextVersions       StrategyVersion[]     @relation("VersionLineage")
  entity             Entity                @relation(fields: [entityId], references: [id], onDelete: Cascade)

  @@unique([entityId, versionNumber])
  @@index([entityId])
  @@index([pivotedFromId])
  @@map("strategy_versions")
}

/// الاتجاه الاستراتيجي (الهرم الاستراتيجي)
model StrategicDirection {
  id            String          @id @default(cuid())
  versionId     String
  type          String
  content       String
  order         Int             @default(0)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  departmentKey String?
  version       StrategyVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)

  @@index([versionId])
  @@index([type])
  @@map("strategic_directions")
}

/// التحليل الخارجي
model ExternalAnalysis {
  id          String          @id @default(cuid())
  versionId   String
  type        String
  factor      String
  impact      String          @default("MEDIUM")
  probability Float?
  trend       String?
  notes       String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  version     StrategyVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)

  @@index([versionId])
  @@index([type])
  @@map("external_analyses")
}

/// الأهداف الاستراتيجية — محسّنة مع BSC + OKR
model StrategicObjective {
  id            String               @id @default(cuid())
  versionId     String
  title         String
  description   String?
  status        String               @default("DRAFT")
  parentId      String?
  perspective   String?
  weight        Float?               @default(1.0)
  baselineValue Float?
  targetValue   Float?
  deadline      DateTime?
  ownerId       String?
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  framework     String?              @default("BSC")
  progress      Float?               @default(0)
  quarter       String?
  kpis          KPI[]
  parent        StrategicObjective?  @relation("ObjectiveHierarchy", fields: [parentId], references: [id])
  children      StrategicObjective[] @relation("ObjectiveHierarchy")
  version       StrategyVersion      @relation(fields: [versionId], references: [id], onDelete: Cascade)

  @@index([versionId])
  @@index([parentId])
  @@map("strategic_objectives")
}

/// مؤشرات الأداء (KPI) — محسّنة
model KPI {
  id                String              @id @default(cuid())
  versionId         String
  objectiveId       String?
  name              String
  nameAr            String?
  description       String?
  target            Float
  actual            Float?
  unit              String              @default("%")
  status            String              @default("ON_TRACK")
  formula           String?
  dataSource        String?
  frequency         String?             @default("MONTHLY")
  warningThreshold  Float?
  criticalThreshold Float?
  kpiType           String?
  bscPerspective    String?
  direction         String              @default("HIGHER_IS_BETTER")
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  diagnoses         KpiDiagnosis[]
  entries           KPIEntry[]
  objective         StrategicObjective? @relation(fields: [objectiveId], references: [id])
  version           StrategyVersion     @relation(fields: [versionId], references: [id], onDelete: Cascade)

  @@unique([versionId, name])
  @@index([versionId])
  @@index([objectiveId])
  @@map("kpis")
}

/// إدخالات الأداء — سجل تاريخي لقيم KPI
model KPIEntry {
  id          String   @id @default(cuid())
  kpiId       String
  value       Float
  periodStart DateTime
  periodEnd   DateTime
  enteredBy   String?
  status      String   @default("CONFIRMED")
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  kpi         KPI      @relation(fields: [kpiId], references: [id], onDelete: Cascade)

  @@index([kpiId])
  @@index([periodStart])
  @@map("kpi_entries")
}

/// المبادرات الاستراتيجية — محسّنة
model StrategicInitiative {
  id          String           @id @default(cuid())
  versionId   String
  title       String
  description String?
  owner       String?
  status      String           @default("PLANNED")
  startDate   DateTime?
  endDate     DateTime?
  progress    Float?           @default(0)
  budget      Float?
  kpiId       String?
  priority    String?          @default("MEDIUM")
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  category    String?
  autoCreated Boolean          @default(false)
  budgetSpent Float?           @default(0)
  kpis        InitiativeKpi[]
  tasks       InitiativeTask[]
  milestones  Milestone[]
  raciEntries RaciEntry[]
  version     StrategyVersion  @relation(fields: [versionId], references: [id], onDelete: Cascade)

  @@unique([versionId, title])
  @@index([versionId])
  @@map("strategic_initiatives")
}

model StrategicProject {
  id          String          @id @default(cuid())
  versionId   String
  name        String
  description String?
  initiative  String?
  objective   String?
  status      String          @default("planning")
  progress    Int             @default(0)
  startDate   DateTime?
  endDate     DateTime?
  manager     String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  version     StrategyVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)

  @@index([versionId])
  @@map("strategic_projects")
}

model InitiativeTask {
  id           String              @id @default(cuid())
  initiativeId String
  title        String
  status       String              @default("PENDING")
  dueDate      DateTime?
  order        Int                 @default(0)
  createdAt    DateTime            @default(now())
  initiative   StrategicInitiative @relation(fields: [initiativeId], references: [id], onDelete: Cascade)

  @@index([initiativeId])
  @@map("initiative_tasks")
}

model InitiativeKpi {
  id           String              @id @default(cuid())
  initiativeId String
  name         String
  target       Float
  current      Float               @default(0)
  unit         String?
  createdAt    DateTime            @default(now())
  initiative   StrategicInitiative @relation(fields: [initiativeId], references: [id], onDelete: Cascade)

  @@index([initiativeId])
  @@map("initiative_kpis")
}

/// المراجعات الاستراتيجية — محسّنة مع محرك القرارات
model StrategicReview {
  id              String          @id @default(cuid())
  versionId       String
  title           String
  reviewDate      DateTime
  status          String          @default("PENDING")
  notes           String?
  type            String?         @default("QUARTERLY_REVIEW")
  decision        String?
  summary         String?
  findings        String?
  recommendations String?
  overallScore    Float?
  conductedBy     String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  version         StrategyVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)

  @@index([versionId])
  @@map("strategic_reviews")
}

/// التقييمات الاستراتيجية
model Assessment {
  id             String          @id @default(cuid())
  entityId       String
  title          String
  description    String?
  status         String          @default("DRAFT")
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  analysisPoints AnalysisPoint[]
  entity         Entity          @relation(fields: [entityId], references: [id], onDelete: Cascade)
  dimensions     Dimension[]
  towsStrategies TOWSStrategy[]

  @@index([entityId])
  @@map("assessments")
}

/// أبعاد التقييم
model Dimension {
  id           String      @id @default(cuid())
  assessmentId String
  name         String
  description  String?
  weight       Float       @default(1.0)
  orderIndex   Int         @default(0)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  criteria     Criterion[]
  assessment   Assessment  @relation(fields: [assessmentId], references: [id], onDelete: Cascade)

  @@index([assessmentId])
  @@map("dimensions")
}

/// معايير التقييم
model Criterion {
  id          String    @id @default(cuid())
  dimensionId String
  name        String
  description String?
  score       Float?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  dimension   Dimension @relation(fields: [dimensionId], references: [id], onDelete: Cascade)

  @@index([dimensionId])
  @@map("criteria")
}

/// الخيارات الاستراتيجية — محسّنة مع Ansoff + Porter
model StrategicChoice {
  id                   String          @id @default(cuid())
  versionId            String
  title                String
  description          String?
  status               String          @default("ACTIVE")
  priority             String          @default("MEDIUM")
  choiceType           String?
  marketAttractiveness Int?
  competitiveAdvantage Int?
  feasibility          Int?
  riskLevel            String?         @default("MEDIUM")
  isSelected           Boolean         @default(false)
  requiredCapabilities String?
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt
  version              StrategyVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)
  risks                StrategicRisk[]

  @@index([versionId])
  @@map("strategic_choices")
}

/// المخاطر الاستراتيجية — محسّنة مع تقييم كمّي
model StrategicRisk {
  id               String            @id @default(cuid())
  choiceId         String?
  versionId        String
  title            String
  description      String?
  probability      String            @default("MEDIUM")
  impact           String            @default("MEDIUM")
  mitigation       String?
  owner            String?
  status           String            @default("OPEN")
  category         String?
  probabilityScore Int?
  impactScore      Int?
  riskScore        Int?
  contingency      String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  stakeholders     StakeholderRisk[]
  version          StrategyVersion   @relation(fields: [versionId], references: [id], onDelete: Cascade)
  choice           StrategicChoice?  @relation(fields: [choiceId], references: [id])

  @@index([choiceId])
  @@index([versionId])
  @@map("strategic_risks")
}

/// أصحاب المصلحة — تحليل القوة والاهتمام
model Stakeholder {
  id            String            @id @default(cuid())
  entityId      String
  name          String
  role          String?
  type          String            @default("EXTERNAL")
  influence     Int               @default(3)
  interest      Int               @default(3)
  strategy      String            @default("inform")
  position      String            @default("NEUTRAL")
  engagement    Int               @default(50)
  needs         String?
  expectations  String?
  contactInfo   String?
  lastContactAt DateTime?
  meetingsCount Int               @default(0)
  color         String?
  createdBy     String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  risks         StakeholderRisk[]
  entity        Entity            @relation(fields: [entityId], references: [id], onDelete: Cascade)

  @@index([entityId])
  @@index([type])
  @@index([strategy])
  @@map("stakeholders")
}

/// جدول الربط: أصحاب المصلحة × المخاطر (Many-to-Many)
model StakeholderRisk {
  id            String        @id @default(cuid())
  stakeholderId String
  riskId        String
  impactLevel   String        @default("MEDIUM")
  impactType    String?
  notes         String?
  createdAt     DateTime      @default(now())
  risk          StrategicRisk @relation(fields: [riskId], references: [id], onDelete: Cascade)
  stakeholder   Stakeholder   @relation(fields: [stakeholderId], references: [id], onDelete: Cascade)

  @@unique([stakeholderId, riskId])
  @@index([stakeholderId])
  @@index([riskId])
  @@map("stakeholder_risks")
}

/// تشخيص سبب ضعف مؤشر الأداء
model KpiDiagnosis {
  id          String             @id @default(cuid())
  kpiId       String
  diagnosis   String
  severity    String             @default("MEDIUM")
  rootCause   String?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  corrections CorrectionAction[]
  kpi         KPI                @relation(fields: [kpiId], references: [id], onDelete: Cascade)

  @@index([kpiId])
  @@map("kpi_diagnoses")
}

/// الإجراء التصحيحي المرتبط بتشخيص
model CorrectionAction {
  id              String         @id @default(cuid())
  diagnosisId     String
  title           String
  description     String?
  assignee        String?
  status          String         @default("PENDING")
  dueDate         DateTime?
  completedAt     DateTime?
  analysisPointId String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  analysisPoint   AnalysisPoint? @relation(fields: [analysisPointId], references: [id])
  diagnosis       KpiDiagnosis   @relation(fields: [diagnosisId], references: [id], onDelete: Cascade)

  @@index([diagnosisId])
  @@index([analysisPointId])
  @@map("correction_actions")
}

/// نقاط التحليل الاستراتيجي (SWOT) — مُحسّنة مع ترميز تلقائي
model AnalysisPoint {
  id           String             @id @default(cuid())
  assessmentId String
  type         String
  title        String
  description  String?
  impact       String             @default("MEDIUM")
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  code         String?
  assessment   Assessment         @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  corrections  CorrectionAction[]
  towsExternal TOWSStrategy[]     @relation("ExternalPoint")
  towsInternal TOWSStrategy[]     @relation("InternalPoint")

  @@index([assessmentId])
  @@index([type])
  @@map("analysis_points")
}

model TOWSStrategy {
  id              String        @id @default(cuid())
  assessmentId    String
  quadrant        String
  internalPointId String
  externalPointId String
  strategy        String
  priority        String        @default("MEDIUM")
  status          String        @default("PROPOSED")
  notes           String?
  initiativeId    String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  externalPoint   AnalysisPoint @relation("ExternalPoint", fields: [externalPointId], references: [id], onDelete: Cascade)
  internalPoint   AnalysisPoint @relation("InternalPoint", fields: [internalPointId], references: [id], onDelete: Cascade)
  assessment      Assessment    @relation(fields: [assessmentId], references: [id], onDelete: Cascade)

  @@index([assessmentId])
