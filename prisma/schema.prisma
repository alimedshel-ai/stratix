// =========================================
// 21. SCENARIO PLANNING (NEW ✨)
// محاكاة السيناريوهات — ماذا لو؟
// =========================================

/// سيناريو استراتيجي — متفائل / متشائم / أساسي
model Scenario {
  id          String  @id @default(cuid())
  versionId   String
  name        String // "السيناريو المتفائل"
  nameEn      String?
  type        String  @default("CUSTOM") // OPTIMISTIC, PESSIMISTIC, BASELINE, CUSTOM
  description String?
  probability Float?  @default(50) // احتمالية حدوث السيناريو (0-100)
  impact      String? @default("MEDIUM") // HIGH, MEDIUM, LOW
  status      String  @default("DRAFT") // DRAFT, ACTIVE, ARCHIVED

  // ✨ التأثير المالي الإجمالي
  totalBudgetChange  Float? @default(0) // التغيير في الميزانية الكلية (%)
  totalRevenueChange Float? @default(0) // التغيير في الإيرادات (%)
  overallImpactScore Float? @default(0) // درجة التأثير الكلي (0-100)

  // ✨ توزيع الميزانية حسب الآفاق
  h1BudgetPct Float? @default(70) // % ميزانية الأفق 1
  h2BudgetPct Float? @default(20) // % ميزانية الأفق 2
  h3BudgetPct Float? @default(10) // % ميزانية الأفق 3

  notes String?

  createdBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  version   StrategyVersion    @relation(fields: [versionId], references: [id], onDelete: Cascade)
  variables ScenarioVariable[]

  @@index([versionId])
  @@index([type])
  @@index([status])
  @@map("scenarios")
}

/// متغيرات السيناريو — تعديل KPIs والمبادرات
model ScenarioVariable {
  id         String @id @default(cuid())
  scenarioId String

  // ✨ ما الذي يتغير؟
  variableType  String // KPI, INITIATIVE, BUDGET, REVENUE, COST, CUSTOM
  referenceId   String? // ID المؤشر أو المبادرة المرتبطة
  referenceName String? // اسم العنصر (للعرض)

  // ✨ مقدار التغيير
  baselineValue Float? // القيمة الأصلية
  adjustedValue Float? // القيمة المعدّلة
  changePercent Float? @default(0) // نسبة التغيير (%)
  changeType    String @default("PERCENT") // PERCENT, ABSOLUTE

  // ✨ التأثير
  impactArea  String? // FINANCIAL, OPERATIONAL, CUSTOMER, GROWTH
  impactScore Float?  @default(0) // تأثير هذا المتغير (0-100)
  notes       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  scenario Scenario @relation(fields: [scenarioId], references: [id], onDelete: Cascade)

  @@index([scenarioId])
  @@index([variableType])
  @@map("scenario_variables")
}

// =========================================
// PHASE 2: COLLABORATION & COMMUNICATION
// =========================================

/// تعليق — يمكن ربطه بأي عنصر (هدف، مبادرة، KPI...)
model Comment {
  id      String @id @default(cuid())
  content String

  // الربط البوليمورفي — نوع + ID العنصر
  targetType String // OBJECTIVE, INITIATIVE, PROJECT, TASK, KPI, REVIEW, ASSESSMENT
  targetId   String // ID العنصر المستهدف
  targetName String? // اسم العنصر (للعرض)

  // المستخدم
  userId     String
  userName   String // اسم المعلّق (للعرض السريع)
  userAvatar String?

  // @mention
  mentions String? // قائمة IDs المذكورين مفصولة بفواصل

  // ردود
  parentId String? // تعليق أب (للردود)

  entityId String? // الكيان المرتبط

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([targetType, targetId])
  @@index([userId])
  @@index([entityId])
  @@index([parentId])
  @@map("comments")
}

/// سجل النشاطات — يتتبع كل الأحداث
model Activity {
  id String @id @default(cuid())

  // نوع النشاط
  action String // CREATED, UPDATED, DELETED, COMPLETED, COMMENTED, APPROVED, REJECTED

  // العنصر المتأثر
  targetType String // OBJECTIVE, INITIATIVE, PROJECT, TASK, KPI, REVIEW, ASSESSMENT, COMMENT
  targetId   String
  targetName String? // اسم العنصر (للعرض)

  // تفاصيل إضافية
  details String? // JSON string — تفاصيل التغيير

  // المستخدم
  userId     String
  userName   String
  userAvatar String?

  entityId String? // الكيان المرتبط

  createdAt DateTime @default(now())

  @@index([entityId])
  @@index([userId])
  @@index([targetType, targetId])
  @@index([createdAt])
  @@map("activities")
}

// =========================================
// 22. STATISTICAL DATA (بيانات إحصائية)
// =========================================

/// مجموعة بيانات إحصائية — مثل "بيانات السوق الصحي 2025"
model StatisticalDataset {
  id          String  @id @default(cuid())
  name        String // اسم المجموعة
  nameAr      String? // اسم عربي
  description String? // وصف المجموعة

  // التصنيف
  category  String // MARKET, DEMOGRAPHIC, FINANCIAL, OPERATIONAL, INDUSTRY, COMPETITIVE, REGULATORY, CUSTOM
  source    String? // المصدر (هيئة الإحصاء، وزارة الصحة...)
  sourceUrl String? // رابط المصدر
  year      Int? // السنة المرجعية

  // ملف الرفع الأصلي
  fileName String?
  fileType String? // xlsx, csv

  // الربط
  entityId   String?
  uploadedBy String? // user ID

  status String @default("ACTIVE") // ACTIVE, ARCHIVED

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  records StatisticalRecord[]

  @@index([entityId])
  @@index([category])
  @@index([year])
  @@map("statistical_datasets")
}

// =========================================
// 23. COMPANY PATTERN (نمط الشركة)
// =========================================

/// نمط الشركة المبني على الألم والطموح
model CompanyPattern {
  id        String  @id @default(cuid())
  companyId String  @unique
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  pain     String // نوع الألم (growth-stopped, team-chaos, etc.)
  ambition String // الطموح (rapid-growth, stability, etc.)
  budget   Float  @default(20000)
  pattern  String // النمط المحسوب (ناشئة متعثرة, نامية فوضوية, etc.)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("company_patterns")
}

/// سجل بيانات إحصائية فردي — صف واحد
model StatisticalRecord {
  id        String             @id @default(cuid())
  datasetId String
  dataset   StatisticalDataset @relation(fields: [datasetId], references: [id], onDelete: Cascade)

  // البيانات
  indicator   String // اسم المؤشر/البند
  indicatorAr String? // الاسم العربي
  value       Float? // القيمة الرقمية
  textValue   String? // قيمة نصية (للبيانات غير الرقمية)
  unit        String? // الوحدة

  // سياق إضافي
  period      String? // الفترة (Q1 2025, يناير 2025)
  region      String? // المنطقة الجغرافية
  subCategory String? // تصنيف فرعي
  notes       String? // ملاحظات

  // ترتيب
  sortOrder Int @default(0)

  createdAt DateTime @default(now())

  @@index([datasetId])
  @@index([indicator])
  @@map("statistical_records")
}

/// FinancialDecision model - القرارات المالية
model FinancialDecision {
  id          String    @id @default(cuid())
  entityId    String?
  versionId   String?
  title       String
  type        String    @default("INVESTMENT") // INVESTMENT, COST_REDUCTION, BUDGET_ALLOCATION, REVENUE_TARGET
  amount      Float?
  currency    String    @default("SAR")
  status      String    @default("PENDING") // PENDING, APPROVED, IN_PROGRESS, COMPLETED, REJECTED
  priority    String    @default("MEDIUM") // LOW, MEDIUM, HIGH, CRITICAL
  description String?
  impact      String? // وصف التأثير المتوقع
  approvedBy  String?
  approvedAt  DateTime?
  dueDate     DateTime?
  notes       String?
  createdBy   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  entity  Entity?          @relation(fields: [entityId], references: [id], onDelete: SetNull)
  version StrategyVersion? @relation(fields: [versionId], references: [id], onDelete: SetNull)

  @@index([entityId])
  @@index([versionId])
  @@index([status])
  @@map("financial_decisions")
}

/// Integration model - التكاملات الخارجية
model Integration {
  id          String    @id @default(cuid())
  entityId    String?
  name        String
  type        String    @default("WEBHOOK") // WEBHOOK, API, BITRIX24, ZAPIER, CUSTOM
  provider    String? // اسم المزود
  webhookUrl  String? // رابط الويب هوك
  apiKey      String? // مفتاح API
  config      String? // إعدادات التكامل (JSON string)
  status      String    @default("INACTIVE") // ACTIVE, INACTIVE, ERROR
  isActive    Boolean   @default(false)
  lastSyncAt  DateTime?
  syncCount   Int       @default(0)
  errorLog    String?
  description String?
  createdBy   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  entity Entity? @relation(fields: [entityId], references: [id], onDelete: SetNull)

  @@index([entityId])
  @@index([type])
  @@map("integrations")
}

// =========================================
// CFO BOARD PITCH — الفحص المالي + الخطة الآلية
// =========================================

/// المعايير المرجعية لكل قطاع
model FinancialBenchmark {
  id               String   @id @default(cuid())
  sectorId         String   @unique
  sectorName       String

  collectionDays   Int      @default(45)
  profitMargin     Float    @default(0.15)
  cashRunwayMonths Int      @default(3)
  debtToEquity     Float    @default(0.5)
  currentRatio     Float    @default(1.5)

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@map("financial_benchmarks")
}

/// إدخالات الفحص المالي — 3 أرقام + 5 نوعية
model FinancialAudit {
  id               String   @id @default(cuid())
  departmentId     String
  userId           String

  // الأرقام الثلاثة
  netMargin        Float
  collectionDays   Int
  cashRunwayMonths Float

  // الاستبيان النوعي
  automationLevel  String   // high / medium / low
  dataSpeed        String   // instant / days / weeks
  strategicRole    String   // full / limited / recorder
  teamSkill        String   // advanced / basic
  executionBarrier String   // authority / culture / resources

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  department       Department         @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  user             User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  strategicPlan    AutoStrategicPlan?

  @@index([departmentId])
  @@index([userId])
  @@map("financial_audits")
}

/// الخطة الاستراتيجية المولّدة آلياً من محرك الاستنتاج
model AutoStrategicPlan {
  id                    String    @id @default(cuid())
  departmentId          String
  auditId               String    @unique

  // SWOT (JSON strings — متوافق مع SQLite)
  strengths             String    // JSON array
  weaknesses            String    // JSON array
  opportunities         String    // JSON array
  threats               String    // JSON array

  // الأهداف المقترحة
  suggestedGoals        String    // JSON array of objects

  // خطاب مجلس الإدارة
  boardPitchText        String

  // الأرقام المحسوبة فعلياً
  calculatedRisk        String
  calculatedSaving      Float
  calculatedImprovement Float

  maturityLevel         String    // Operational / Tactical / Strategic
  score                 Int       // 0-100

  isApproved            Boolean   @default(false)
  approvedAt            DateTime?

  audit                 FinancialAudit @relation(fields: [auditId], references: [id], onDelete: Cascade)

  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([departmentId])
  @@map("auto_strategic_plans")
}

// =========================================
// LEADS — صدمة الواقع (Ambition Gap)
// =========================================
model Lead {
  id            String   @id @default(cuid())
  email         String   @unique
  sector        String               // القطاع (retail, fnb, tech, services)
  pains         String   @default("") // JSON array of pain types
  currentSales  Float?               // المبيعات الحالية (اختياري)
  targetSales   Float?               // المبيعات المستهدفة (اختياري)
  gapPercent    Int?                 // نسبة الفجوة (اختياري)
  details       String?              // JSON object with pain-specific details
  pdplConsent   Boolean  @default(false)  // موافقة PDPL
  source        String   @default("ambition_gap")  // مصدر الـ lead
  status        String   @default("new")  // new, contacted, converted, archived
  notes         String?              // ملاحظات إدارية

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([sector])
  @@index([status])
  @@map("leads")
}

// =========================================
// PHASE: FINANCIAL TOOLS (الأدوات المالية)
// DuPont, Break-even, ABC Costing
// =========================================

/// تحليل DuPont — تفكيك العائد على حقوق الملكية
model DupontAnalysis {
  id            String @id @default(cuid())
  entityId      String
  versionId     String?
  fiscalYear    Int
  fiscalQuarter Int?   // 1-4 (اختياري)

  // المدخلات الأساسية
  revenue       Float  // الإيرادات
  netIncome     Float  // صافي الربح
  totalAssets   Float  // إجمالي الأصول
  totalEquity   Float  // إجمالي حقوق الملكية

  // النتائج المحسوبة (يُحسب في Backend)
  profitMargin     Float? // هامش الربح = netIncome / revenue
  assetTurnover    Float? // دوران الأصول = revenue / totalAssets
  equityMultiplier Float? // مضاعف حقوق الملكية = totalAssets / totalEquity
  roe              Float? // العائد على حقوق الملكية = profitMargin × assetTurnover × equityMultiplier

  notes     String?
  createdBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([entityId, fiscalYear, fiscalQuarter])
  @@index([entityId])
  @@index([fiscalYear])
  @@map("dupont_analyses")
}

/// تحليل نقطة التعادل — Break-even Analysis
model BreakevenAnalysis {
  id            String @id @default(cuid())
  entityId      String
  versionId     String?
  productName   String // اسم المنتج أو الخدمة

  // المدخلات
  fixedCosts    Float  // التكاليف الثابتة
  variableCost  Float  // التكلفة المتغيرة للوحدة
  sellingPrice  Float  // سعر البيع للوحدة

  // النتائج المحسوبة (Backend)
  breakevenUnits   Float? // وحدات التعادل = fixedCosts / (sellingPrice - variableCost)
  breakevenRevenue Float? // إيرادات التعادل = breakevenUnits × sellingPrice
  contributionMargin Float? // هامش المساهمة = (sellingPrice - variableCost) / sellingPrice
  marginOfSafety   Float? // هامش الأمان (%) — اختياري

  actualUnits  Float? // الوحدات الفعلية المباعة (للمقارنة)
  notes        String?
  createdBy    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([entityId])
  @@map("breakeven_analyses")
}

/// أنشطة ABC Costing — تحديد محركات التكلفة
model AbcActivity {
  id            String @id @default(cuid())
  entityId      String
  versionId     String?
  nameAr        String // اسم النشاط بالعربي
  nameEn        String? // اسم النشاط بالإنجليزي
  costDriver    String // محرك التكلفة (ساعات عمل، عدد طلبات...)
  totalCost     Float  // إجمالي تكلفة النشاط
  driverQuantity Float // إجمالي كمية المحرك
  ratePerDriver Float? // معدل التكلفة لكل وحدة محرك (محسوب)

  createdBy     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  productCosts  AbcProductCost[]

  @@index([entityId])
  @@map("abc_activities")
}

/// توزيع تكاليف ABC على المنتجات
model AbcProductCost {
  id           String @id @default(cuid())
  activityId   String
  productName  String // اسم المنتج
  driverUsage  Float  // استخدام المنتج لمحرك التكلفة
  allocatedCost Float? // التكلفة المخصصة (محسوب)

  createdAt    DateTime @default(now())

  activity AbcActivity @relation(fields: [activityId], references: [id], onDelete: Cascade)

  @@index([activityId])
  @@map("abc_product_costs")
}

// =========================================
// PHASE: INTELLIGENCE TOOLS (أدوات الذكاء)
// Monte Carlo, Process Mining
// =========================================

/// محاكاة Monte Carlo — تحليل احتمالي
model MonteCarloRun {
  id          String @id @default(cuid())
  entityId    String
  versionId   String?
  name        String // اسم المحاكاة
  description String?

  iterations  Int    @default(10000) // عدد التكرارات
  variables   String // JSON: [{name, min, max, distribution, mostLikely}]
  results     String? // JSON: {mean, median, p5, p25, p75, p95, stdDev, histogram}

  status      String @default("PENDING") // PENDING, RUNNING, COMPLETED, FAILED
  createdBy   String?
  createdAt   DateTime @default(now())

  @@index([entityId])
  @@index([versionId])
  @@map("monte_carlo_runs")
}

/// سجلات العمليات — Process Mining Event Log
model ProcessLog {
  id            String   @id @default(cuid())
  entityId      String
  processName   String   // اسم العملية
  caseId        String   // معرف الحالة/الطلب
  activity      String   // النشاط (مثال: "تقديم الطلب"، "المراجعة")
  startedAt     DateTime // وقت البداية
  completedAt   DateTime? // وقت الانتهاء
  durationMins  Float?   // المدة بالدقائق
  performerId   String?  // المنفذ (user ID)
  departmentId  String?  // القسم
  metadata      String?  // JSON — بيانات إضافية

  createdAt     DateTime @default(now())

  @@index([entityId, processName])
  @@index([caseId])
  @@index([startedAt])
  @@map("process_logs")
}

/// اختناقات العمليات — نتائج تحليل Process Mining
model ProcessBottleneck {
  id              String @id @default(cuid())
  entityId        String
  processName     String
  activity        String   // النشاط المتسبب في الاختناق
  avgDuration     Float?   // متوسط المدة (دقائق)
  caseCount       Int?     // عدد الحالات المتأثرة
  bottleneckScore Float?   // درجة الاختناق (0-100)
  recommendation  String?  // توصية التحسين

  detectedAt      DateTime @default(now())

  @@index([entityId])
  @@index([processName])
  @@map("process_bottlenecks")
}

// =========================================
// PHASE: EXECUTION TOOLS (أدوات التنفيذ)
// Milestones (Gantt), RACI Matrix
// =========================================

/// معالم المبادرة — لمخطط جانت
model Milestone {
  id            String   @id @default(cuid())
  initiativeId  String
  title         String
  startDate     DateTime
  endDate       DateTime
  progress      Float    @default(0) // 0-100
  dependsOnId   String?  // معلم سابق يعتمد عليه
  sortOrder     Int      @default(0)
  color         String?  // لون شريط جانت

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  initiative StrategicInitiative @relation(fields: [initiativeId], references: [id], onDelete: Cascade)
  dependsOn  Milestone?          @relation("MilestoneDep", fields: [dependsOnId], references: [id])
  dependents Milestone[]         @relation("MilestoneDep")

  @@index([initiativeId])
  @@map("milestones")
}

/// مصفوفة RACI — تحديد المسؤوليات
model RaciEntry {
  id            String @id @default(cuid())
  initiativeId  String
  activity      String // النشاط/المهمة
  responsibleId String? // المسؤول عن التنفيذ (R)
  accountableId String? // المعتمد/المحاسب (A)
  consulted     String? // المستشارون — JSON array of user IDs (C)
  informed      String? // المُطّلعون — JSON array of user IDs (I)
  notes         String?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  initiative StrategicInitiative @relation(fields: [initiativeId], references: [id], onDelete: Cascade)

  @@index([initiativeId])
  @@map("raci_entries")
}

// =========================================
// PHASE: OKR KEY RESULTS
// النتائج الرئيسية لأهداف OKR
// =========================================

/// النتائج الرئيسية — Key Results لكل OKR Objective
model OkrKeyResult {
  id           String @id @default(cuid())
  objectiveId  String // ربط بـ StrategicObjective (framework='OKR')
  title        String
  metricType   String @default("PERCENTAGE") // NUMBER, PERCENTAGE, CURRENCY, BOOLEAN
  startValue   Float  @default(0)
  targetValue  Float
  currentValue Float  @default(0)
  progress     Float? @default(0) // محسوب: ((current - start) / (target - start)) × 100
  ownerId      String? // مسؤول النتيجة
  status       String @default("NOT_STARTED") // NOT_STARTED, IN_PROGRESS, AT_RISK, ACHIEVED

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([objectiveId])
  @@map("okr_key_results")
}

// =========================================
// PHASE: AI RECOMMENDATIONS
// توصيات الذكاء الاصطناعي
// =========================================

/// توصيات AI — جاهزة للترقية من rule-based إلى ML
model AiRecommendation {
  id             String  @id @default(cuid())
  entityId       String
  kpiId          String? // KPI المرتبط (اختياري)
  departmentId   String? // القسم المرتبط (اختياري)
  recommendation String  // نص التوصية
  reasoning      String? // سبب التوصية
  confidence     Float?  @default(0.75) // 0-1 مستوى الثقة
  sourceType     String  @default("RULE_BASED") // RULE_BASED, ML_MODEL, HYBRID
  category       String? // FINANCIAL, OPERATIONAL, STRATEGIC, HR
  priority       String  @default("MEDIUM") // HIGH, MEDIUM, LOW
  isDismissed    Boolean @default(false)
  isImplemented  Boolean @default(false)

  createdAt      DateTime @default(now())

  @@index([entityId])
  @@index([kpiId])
  @@index([isDismissed])
  @@map("ai_recommendations")
}
