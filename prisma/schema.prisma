  @@index([decisionById])
  @@index([sector])
  @@map("investment_deals")
}

/// مستندات الفرصة — ملفات مرفقة (PDF, صور, ...)
model DealDocument {
  id         String         @id @default(cuid())
  dealId     String
  fileName   String
  fileUrl    String
  fileType   String         @default("OTHER")
  fileSize   Int?
  mimeType   String?
  uploadedBy String
  createdAt  DateTime       @default(now())
  deal       InvestmentDeal @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@index([dealId])
  @@index([fileType])
  @@map("deal_documents")
}

/// تقارير تحليل الفرصة — مالي، سوقي، قانوني، موحد
model DealAnalysisReport {
  id             String         @id @default(cuid())
  dealId         String
  type           String
  analystId      String
  summary        String?
  score          Float?
  riskLevel      String?
  findings       String?
  recommendation String?
  status         String         @default("DRAFT")
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  deal           InvestmentDeal @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@index([dealId])
  @@index([analystId])
  @@index([type])
  @@map("deal_analysis_reports")
}

/// شركة في المحفظة — بعد الموافقة على الاستثمار
model PortfolioCompany {
  id                String            @id @default(cuid())
  dealId            String            @unique
  companyName       String
  investedAmount    Float
  equityPercent     Float
  investedAt        DateTime
  status            String            @default("ACTIVE")
  exitedAt          DateTime?
  exitValue         Float?
  exitType          String?
  assignedAnalystId String?
  reportFrequency   String            @default("QUARTERLY")
  nextReportDue     DateTime?
  lastRevenue       Float?
  lastNetProfit     Float?
  currentHealth     String            @default("HEALTHY")
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  deal              InvestmentDeal    @relation(fields: [dealId], references: [id], onDelete: Cascade)
  reports           PortfolioReport[]

  @@index([status])
  @@index([assignedAnalystId])
  @@map("portfolio_companies")
}

/// تقارير المتابعة الدورية — شهرية/ربعية
model PortfolioReport {
  id                 String           @id @default(cuid())
  portfolioCompanyId String
  period             String
  periodType         String           @default("QUARTERLY")
  revenue            Float?
  expenses           Float?
  netProfit          Float?
  cashFlow           Float?
  burnRate           Float?
  kpis               String?
  headcount          Int?
  customers          Int?
  highlights         String?
  challenges         String?
  risks              String?
  nextSteps          String?
  status             String           @default("DRAFT")
  createdBy          String
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  portfolioCompany   PortfolioCompany @relation(fields: [portfolioCompanyId], references: [id], onDelete: Cascade)

  @@index([portfolioCompanyId])
  @@index([period])
  @@map("portfolio_reports")
}

/// الإشعارات — نظام إشعارات موحد للنظام بالكامل
model Notification {
  id         String    @id @default(cuid())
  userId     String
  type       String
  title      String
  message    String
  link       String?
  icon       String?
  isRead     Boolean   @default(false)
  readAt     DateTime?
  sourceType String?
  sourceId   String?
  createdAt  DateTime  @default(now())

  @@index([userId, isRead])
  @@index([userId, createdAt])
  @@index([type])
  @@map("notifications")
}

/// تقارير صحة الشركة — مؤشرات حية من كل إدارة
model CompanyHealthReport {
  id             String   @id @default(cuid())
  entityId       String
  dimension      String
  indicatorName  String
  indicatorValue Float
  targetValue    Float
  unit           String
  department     String
  reportDate     DateTime
  notes          String?
  reporterId     String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  reporter       User     @relation("HealthReporter", fields: [reporterId], references: [id])
  entity         Entity   @relation(fields: [entityId], references: [id], onDelete: Cascade)

  @@index([entityId, reportDate])
  @@index([entityId, dimension])
  @@index([department])
  @@map("company_health_reports")
}

/// أبعاد التقييم (المالي، الإداري، التوطين)
model CompanyDimension {
  id                String    @id @default(cuid())
  entityId          String    @unique
  financialScore    Float?
  revenueStreams    String?
  costStructure     String?
  profitMargins     String?
  financialNotes    String?
  adminScore        Float?
  orgStructure      String?
  governance        String?
  processEffciency  String?
  adminNotes        String?
  localizationScore Float?
  nitaqatLevel      String?
  saudizationRate   Float?
  laborCompliance   String?
  localNotes        String?
  evaluatedBy       String?
  evaluatedAt       DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  entity            Entity    @relation("EntityDimensions", fields: [entityId], references: [id], onDelete: Cascade)

  @@map("company_dimensions")
}

/// إعدادات الـ Webhook الخارجي (Slack, Teams, Zapier, ...)
model Webhook {
  id           String       @id @default(cuid())
  entityId     String
  name         String
  url          String
  platform     String
  icon         String?
  color        String?
  events       String
  active       Boolean      @default(true)
  secret       String?
  calls        Int          @default(0)
  successRate  Float?       @default(100)
  lastCalledAt DateTime?
  createdBy    String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  logs         WebhookLog[]
  entity       Entity       @relation("EntityWebhooks", fields: [entityId], references: [id], onDelete: Cascade)

  @@map("webhooks")
}

/// سجل كل استدعاء للـ Webhook
model WebhookLog {
  id         String   @id @default(cuid())
  webhookId  String
  event      String
  statusCode Int
  ok         Boolean
  durationMs Int?
  error      String?
  payload    String?
  createdAt  DateTime @default(now())
  webhook    Webhook  @relation(fields: [webhookId], references: [id], onDelete: Cascade)

  @@map("webhook_logs")
}

/// صلاحيات صريحة تربط المستخدم بمورد محدد (للـ viewers والحالات الخاصة)
model ResourceAccess {
  id           String    @id @default(cuid())
  resourceType String
  resourceId   String
  userId       String
  permission   String
  grantedBy    String
  grantedAt    DateTime  @default(now())
  expiresAt    DateTime?
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([resourceType, resourceId, userId, permission])
  @@index([userId])
  @@index([resourceType, resourceId])
  @@map("resource_access")
}

/// متتبع المشاكل الاستراتيجية والتشغيلية
model Issue {
  id           String    @id @default(cuid())
  title        String
  description  String?
  type         String    @default("STRATEGIC")
  status       String    @default("OPEN")
  priority     String?   @default("MEDIUM")
  companyId    String?
  investorId   String?
  department   String?
  assignedTo   String?
  createdById  String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  resolvedAt   DateTime?
  resolution   String?
  source       String    @default("MANUAL")
  createdBy    User      @relation("createdIssues", fields: [createdById], references: [id], onDelete: Cascade)
  assignedUser User?     @relation("assignedIssues", fields: [assignedTo], references: [id])
  company      Entity?   @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([investorId])
  @@index([assignedTo])
  @@index([createdById])
  @@map("issues")
}
