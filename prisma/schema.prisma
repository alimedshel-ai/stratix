// =========================================
// 21. SCENARIO PLANNING (NEW ✨)
// محاكاة السيناريوهات — ماذا لو؟
// =========================================

/// سيناريو استراتيجي — متفائل / متشائم / أساسي
model Scenario {
  id            String    @id @default(cuid())
  versionId     String
  name          String            // "السيناريو المتفائل"
  nameEn        String?
  type          String    @default("CUSTOM")  // OPTIMISTIC, PESSIMISTIC, BASELINE, CUSTOM
  description   String?
  probability   Float?    @default(50)  // احتمالية حدوث السيناريو (0-100)
  impact        String?   @default("MEDIUM")  // HIGH, MEDIUM, LOW
  status        String    @default("DRAFT")   // DRAFT, ACTIVE, ARCHIVED
  
  // ✨ التأثير المالي الإجمالي
  totalBudgetChange    Float?  @default(0)  // التغيير في الميزانية الكلية (%)
  totalRevenueChange   Float?  @default(0)  // التغيير في الإيرادات (%)
  overallImpactScore   Float?  @default(0)  // درجة التأثير الكلي (0-100)
  
  // ✨ توزيع الميزانية حسب الآفاق
  h1BudgetPct   Float?   @default(70)  // % ميزانية الأفق 1
  h2BudgetPct   Float?   @default(20)  // % ميزانية الأفق 2
  h3BudgetPct   Float?   @default(10)  // % ميزانية الأفق 3
  
  notes         String?
  
  createdBy     String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  version       StrategyVersion    @relation(fields: [versionId], references: [id], onDelete: Cascade)
  variables     ScenarioVariable[]

  @@index([versionId])
  @@index([type])
  @@index([status])
  @@map("scenarios")
}

/// متغيرات السيناريو — تعديل KPIs والمبادرات
model ScenarioVariable {
  id            String    @id @default(cuid())
  scenarioId    String
  
  // ✨ ما الذي يتغير؟
  variableType  String    // KPI, INITIATIVE, BUDGET, REVENUE, COST, CUSTOM
  referenceId   String?   // ID المؤشر أو المبادرة المرتبطة
  referenceName String?   // اسم العنصر (للعرض)
  
  // ✨ مقدار التغيير
  baselineValue Float?    // القيمة الأصلية
  adjustedValue Float?    // القيمة المعدّلة
  changePercent Float?    @default(0)  // نسبة التغيير (%)
  changeType    String    @default("PERCENT")  // PERCENT, ABSOLUTE
  
  // ✨ التأثير
  impactArea    String?   // FINANCIAL, OPERATIONAL, CUSTOMER, GROWTH
  impactScore   Float?    @default(0)  // تأثير هذا المتغير (0-100)
  notes         String?
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  scenario      Scenario  @relation(fields: [scenarioId], references: [id], onDelete: Cascade)

  @@index([scenarioId])
  @@index([variableType])
  @@map("scenario_variables")
}

// =========================================
// PHASE 2: COLLABORATION & COMMUNICATION
// =========================================

/// تعليق — يمكن ربطه بأي عنصر (هدف، مبادرة، KPI...)
model Comment {
  id          String   @id @default(cuid())
  content     String
  
  // الربط البوليمورفي — نوع + ID العنصر
  targetType  String   // OBJECTIVE, INITIATIVE, PROJECT, TASK, KPI, REVIEW, ASSESSMENT
  targetId    String   // ID العنصر المستهدف
  targetName  String?  // اسم العنصر (للعرض)
  
  // المستخدم
  userId      String
  userName    String   // اسم المعلّق (للعرض السريع)
  userAvatar  String?
  
  // @mention
  mentions    String?  // قائمة IDs المذكورين مفصولة بفواصل
  
  // ردود
  parentId    String?  // تعليق أب (للردود)
  
  entityId    String?  // الكيان المرتبط
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([targetType, targetId])
  @@index([userId])
  @@index([entityId])
  @@index([parentId])
  @@map("comments")
}

/// سجل النشاطات — يتتبع كل الأحداث
model Activity {
  id          String   @id @default(cuid())
  
  // نوع النشاط
  action      String   // CREATED, UPDATED, DELETED, COMPLETED, COMMENTED, APPROVED, REJECTED
  
  // العنصر المتأثر
  targetType  String   // OBJECTIVE, INITIATIVE, PROJECT, TASK, KPI, REVIEW, ASSESSMENT, COMMENT
  targetId    String
  targetName  String?  // اسم العنصر (للعرض)
  
  // تفاصيل إضافية
  details     String?  // JSON string — تفاصيل التغيير
  
  // المستخدم
  userId      String
  userName    String
  userAvatar  String?
  
  entityId    String?  // الكيان المرتبط
  
  createdAt   DateTime @default(now())
  
  @@index([entityId])
  @@index([userId])
  @@index([targetType, targetId])
  @@index([createdAt])
  @@map("activities")
}

// =========================================
// 22. STATISTICAL DATA (بيانات إحصائية)
// =========================================

/// مجموعة بيانات إحصائية — مثل "بيانات السوق الصحي 2025"
model StatisticalDataset {
  id          String   @id @default(cuid())
  name        String   // اسم المجموعة
  nameAr      String?  // اسم عربي
  description String?  // وصف المجموعة
  
  // التصنيف
  category    String   // MARKET, DEMOGRAPHIC, FINANCIAL, OPERATIONAL, INDUSTRY, COMPETITIVE, REGULATORY, CUSTOM
  source      String?  // المصدر (هيئة الإحصاء، وزارة الصحة...)
  sourceUrl   String?  // رابط المصدر
  year        Int?     // السنة المرجعية
  
  // ملف الرفع الأصلي
  fileName    String?
  fileType    String?  // xlsx, csv
  
  // الربط
  entityId    String?
  uploadedBy  String?  // user ID
  
  status      String   @default("ACTIVE") // ACTIVE, ARCHIVED
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  records     StatisticalRecord[]
  
  @@index([entityId])
  @@index([category])
  @@index([year])
  @@map("statistical_datasets")
}

// =========================================
// 23. COMPANY PATTERN (نمط الشركة)
// =========================================

/// نمط الشركة المبني على الألم والطموح
model CompanyPattern {
  id        String   @id @default(cuid())
  companyId String   @unique
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  pain      String   // نوع الألم (growth-stopped, team-chaos, etc.)
  ambition  String   // الطموح (rapid-growth, stability, etc.)
  budget    Float    @default(20000)
  pattern   String   // النمط المحسوب (ناشئة متعثرة, نامية فوضوية, etc.)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("company_patterns")
}

/// سجل بيانات إحصائية فردي — صف واحد
model StatisticalRecord {
  id          String   @id @default(cuid())
  datasetId   String
  dataset     StatisticalDataset @relation(fields: [datasetId], references: [id], onDelete: Cascade)
  
  // البيانات
  indicator   String   // اسم المؤشر/البند
  indicatorAr String?  // الاسم العربي
  value       Float?   // القيمة الرقمية
  textValue   String?  // قيمة نصية (للبيانات غير الرقمية)
  unit        String?  // الوحدة
  
  // سياق إضافي
  period      String?  // الفترة (Q1 2025, يناير 2025)
  region      String?  // المنطقة الجغرافية
  subCategory String?  // تصنيف فرعي
  notes       String?  // ملاحظات
  
  // ترتيب
  sortOrder   Int      @default(0)
  
  createdAt   DateTime @default(now())
  
  @@index([datasetId])
  @@index([indicator])
  @@map("statistical_records")
}

/// FinancialDecision model - القرارات المالية
model FinancialDecision {
  id          String   @id @default(cuid())
  entityId    String?
  versionId   String?
  title       String
  type        String   @default("INVESTMENT") // INVESTMENT, COST_REDUCTION, BUDGET_ALLOCATION, REVENUE_TARGET
  amount      Float?
  currency    String   @default("SAR")
  status      String   @default("PENDING") // PENDING, APPROVED, IN_PROGRESS, COMPLETED, REJECTED
  priority    String   @default("MEDIUM") // LOW, MEDIUM, HIGH, CRITICAL
  description String?
  impact      String?  // وصف التأثير المتوقع
  approvedBy  String?
  approvedAt  DateTime?
  dueDate     DateTime?
  notes       String?
  createdBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  entity      Entity?  @relation(fields: [entityId], references: [id], onDelete: SetNull)
  version     StrategyVersion? @relation(fields: [versionId], references: [id], onDelete: SetNull)

  @@index([entityId])
  @@index([versionId])
  @@index([status])
  @@map("financial_decisions")
}

/// Integration model - التكاملات الخارجية
model Integration {
  id          String   @id @default(cuid())
  entityId    String?
  name        String
  type        String   @default("WEBHOOK") // WEBHOOK, API, BITRIX24, ZAPIER, CUSTOM
  provider    String?  // اسم المزود
  config      String?  // إعدادات التكامل (JSON string)
  status      String   @default("INACTIVE") // ACTIVE, INACTIVE, ERROR
  isActive    Boolean  @default(false)
  lastSyncAt  DateTime?
  syncCount   Int      @default(0)
  errorLog    String?
  description String?
  createdBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  entity      Entity?  @relation(fields: [entityId], references: [id], onDelete: SetNull)

  @@index([entityId])
  @@index([type])
  @@map("integrations")
}
