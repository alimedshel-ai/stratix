// =========================================
// 18. TOOL DEFINITIONS (NEW ✨)
// تعريف أدوات التحليل الاستراتيجي
// =========================================

/// تعريف الأدوات — كتالوج الـ 13 أداة
model ToolDefinition {
  id          String   @id @default(cuid())
  code        String   @unique    // SWOT, PESTEL, PORTER, VRIO, etc.
  nameAr      String              // الاسم بالعربي
  nameEn      String              // الاسم بالإنجليزي
  descriptionAr String?           // الوصف بالعربي
  descriptionEn String?           // الوصف بالإنجليزي
  category    String              // DIAGNOSIS, CHOICE, EXECUTION, ADAPTATION
  isPrimary   Boolean  @default(false)  // أساسية (8) أو متقدمة (5)
  order       Int      @default(0)      // ترتيب العرض
  icon        String?             // أيقونة (Bootstrap Icons class)
  color       String?             // لون البطاقة (hex)
  configSchema String?            // JSON Schema للـ validation
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  companyAnalyses CompanyAnalysis[]

  @@index([category])
  @@index([isPrimary])
  @@map("tool_definitions")
}

// =========================================
// 19. COMPANY ANALYSIS
// =========================================
model CompanyAnalysis {
  id          String    @id @default(cuid())
  versionId   String
  version     StrategyVersion @relation(fields: [versionId], references: [id])
  toolId      String
  tool        ToolDefinition @relation(fields: [toolId], references: [id])
  toolCode    String
  data        String?               // JSON data for the analysis
  summary     String?
  status      String    @default("DRAFT")  // DRAFT, IN_PROGRESS, COMPLETED
  progress    Int       @default(0)
  score       Float?
  createdBy   String?
  updatedBy   String?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([versionId, toolCode])
  @@index([versionId])
  @@index([toolCode])
  @@index([status])
  @@map("company_analyses")
}

