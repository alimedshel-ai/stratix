/// التنبيهات الاستراتيجية
model StrategicAlert {
  id          String   @id @default(cuid())
  entityId    String
  type        String   // KPI_WARNING, KPI_CRITICAL, KPI_ACHIEVED, OBJECTIVE_ACHIEVED,
                       // REVIEW_OVERDUE, INITIATIVE_DELAYED, VERSION_PENDING, RISK_HIGH, HEALTH_LOW
  severity    String   @default("WARNING")  // SUCCESS, INFO, WARNING, CRITICAL
  title       String
  message     String?
  referenceId String?  // ID العنصر المرتبط (KPI ID, Review ID, etc.)
  referenceType String? // KPI, REVIEW, INITIATIVE, RISK, VERSION
  isRead      Boolean  @default(false)
  isDismissed Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([entityId])
  @@index([type])
  @@index([isRead])
  @@map("strategic_alerts")
}

