  @@index([diagnosisId])
  @@index([analysisPointId])
  @@map("correction_actions")
}

// =========================================
// 13. STRATEGY ANALYSIS (SWOT) (ENHANCED ✨)
// ترميز تلقائي + جاهز لربط TOWS
// =========================================

/// نقاط التحليل الاستراتيجي (SWOT) — مُحسّنة مع ترميز تلقائي
model AnalysisPoint {
  id           String   @id @default(cuid())
  assessmentId String
  type         String // STRENGTH, WEAKNESS, OPPORTUNITY, THREAT
  code         String? // ✨ ترميز تلقائي: S1, S2, W1, W2, O1, T1...
  title        String
  description  String?
  impact       String   @default("MEDIUM")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  assessment    Assessment         @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  corrections   CorrectionAction[]
  towsInternal  TOWSStrategy[]     @relation("InternalPoint")
  towsExternal  TOWSStrategy[]     @relation("ExternalPoint")

  @@index([assessmentId])
  @@index([type])
  @@map("analysis_points")
}

